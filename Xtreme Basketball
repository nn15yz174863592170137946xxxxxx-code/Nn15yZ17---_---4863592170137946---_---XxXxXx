-- ===== Auto Release ===== --
local AutoReleaseGroup = Tabs.Main:AddLeftGroupbox("Auto Release", "boxes")
local autoReleaseEnabled = false
local threshold = -0.9231
local activeHooks = {}

local function cleanupIndicator(indicator)
    local hooks = activeHooks[indicator]
    if not hooks then return end
    for _, conn in pairs(hooks) do
        if conn then conn:Disconnect() end
    end
    activeHooks[indicator] = nil
end

local function hookGradient(gradient, indicator)
    local fired = false
    local conn = gradient:GetPropertyChangedSignal("Offset"):Connect(function()
        if not autoReleaseEnabled then return end
        local y = gradient.Offset.Y
        if y <= threshold and not fired then
            fired = true
            shootRemote:FireServer("Stop", false)
        elseif y > threshold then
            fired = false
        end
    end)
    activeHooks[indicator] = activeHooks[indicator] or {}
    table.insert(activeHooks[indicator], conn)
end

local function onPillAppear(pill, indicator)
    if not pill then return end
    local bar = pill:FindFirstChild("MeterUI") and pill.MeterUI:FindFirstChild("Meter") and pill.MeterUI.Meter:FindFirstChild("Bar")
    if bar then
        local grad = bar:FindFirstChild("UIGradient")
        if grad and grad:IsA("UIGradient") then
            hookGradient(grad, indicator)
        else
            local c = bar.ChildAdded:Connect(function(child)
                if child.Name == "UIGradient" and child:IsA("UIGradient") then
                    c:Disconnect()
                    hookGradient(child, indicator)
                end
            end)
            activeHooks[indicator] = activeHooks[indicator] or {}
            table.insert(activeHooks[indicator], c)
        end
    end
end

local function setupIndicator(indicator)
    cleanupIndicator(indicator)
    local meterPart = indicator:FindFirstChild("MeterPart")
    if not meterPart then
        local c = indicator.ChildAdded:Connect(function(child)
            if child.Name == "MeterPart" then
                c:Disconnect()
                setupIndicator(indicator)
            end
        end)
        activeHooks[indicator] = {c}
        return
    end
    local pill = meterPart:FindFirstChild("Pill")
    if pill then onPillAppear(pill, indicator) end
    local c = meterPart.ChildAdded:Connect(function(child)
        if child.Name == "Pill" then
            onPillAppear(child, indicator)
        end
    end)
    activeHooks[indicator] = activeHooks[indicator] or {}
    table.insert(activeHooks[indicator], c)

    local destroyConn = indicator.Destroying:Connect(function()
        destroyConn:Disconnect()
        cleanupIndicator(indicator)
    end)
    table.insert(activeHooks[indicator], destroyConn)
end

local function scanAndHookAll()
    local folder = workspace:FindFirstChild("Local")
    if not folder then return end
    for _, child in ipairs(folder:GetChildren()) do
        if child.Name:find(LocalPlayer.Name) and child.Name:find("CharacterIndicator") then
            if not activeHooks[child] then
                setupIndicator(child)
            end
        end
    end
end

local function fullCleanup()
    for indicator, _ in pairs(activeHooks) do
        cleanupIndicator(indicator)
    end
    activeHooks = {}
end

AutoReleaseGroup:AddToggle("AutoPerfectRelease", {
    Text = "Auto Perfect Release",
    Default = false,
    Callback = function(value)
        autoReleaseEnabled = value
        if value then
            scanAndHookAll()
        else
            fullCleanup()
        end
    end
})

task.spawn(function()
    while true do
        task.wait(1)
        if autoReleaseEnabled then
            scanAndHookAll()
        end
    end
end)

