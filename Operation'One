WLGroup:AddInput("WhitelistInput",{Text="Input",Placeholder="(Partial username)"})

local function findPlayer(txt)
    txt = txt:lower()
    for _,p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(txt) or p.DisplayName:lower():find(txt) then
            return p
        end
    end
end

WLGroup:AddButton("Add",function()
    local p = findPlayer(Options.WhitelistInput.Value)
    if p then WhitelistPlayers[p.Name] = true end
end)

WLGroup:AddButton("Remove",function()
    local p = findPlayer(Options.WhitelistInput.Value)
    if p then WhitelistPlayers[p.Name] = nil end
end)

-- ===== TRACKER DUMMIES =====
local Targets = {}

local function pickPart(plr)
    local m = workspace:FindFirstChild(plr.Name)
    if not m then return end
    if math.random(100) <= headChance then
        return m:FindFirstChild("collision3")
    else
        return m:FindFirstChild("collision")
    end
end

for _,plr in pairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        local d = Instance.new("Part",workspace)
        d.Size = Vector3.new(.2,.2,.2)
        d.Anchored = true
        d.CanCollide = false
        d.Transparency = 1
        Targets[plr] = d

        task.spawn(function()
            while d.Parent do
                if sameTeam(plr) or isDead(plr) then
                    d.CFrame = CFrame.new(0,-10000,0)
                else
                    local p = pickPart(plr)
                    if p then d.CFrame = p.CFrame end
                end
                task.wait(0.01)
            end
        end)
    end
end

-- ===== AIMLOCK (NEAREST TO FOV) =====
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end

        local best,bestDist
        local center = Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2)

        for plr,d in pairs(Targets) do
            if WhitelistPlayers[plr.Name] then continue end
            if sameTeam(plr) then continue end
            if isDead(plr) then continue end

            local sp,on = cam:WorldToViewportPoint(d.Position)
            if not on then continue end

            local dist = (Vector2.new(sp.X,sp.Y)-center).Magnitude
            if dist <= fovSize/2 and (not bestDist or dist < bestDist) then
                bestDist = dist
                best = d
            end
        end

        if best then
            cam.CFrame = CFrame.lookAt(cam.CFrame.Position, best.Position)
        end
    end
end)

