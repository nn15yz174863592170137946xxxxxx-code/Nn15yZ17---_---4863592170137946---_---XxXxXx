-- ===== FOV VISUAL =====
local gui,fovCircle,crossV,crossH,fovStroke
local fovSize = 500

AimGroup:AddInput("FOVSize",{
    Text="FOV Size",
    Default="500",
    Finished=true
}):OnChanged(function(v)
    local n = tonumber(v)
    if n and fovCircle then
        fovSize = n
        fovCircle.Size = UDim2.new(0,n,0,n)
    end
end)

local function createFOV()
    gui = Instance.new("ScreenGui",LocalPlayer.PlayerGui)
    gui.IgnoreGuiInset=true
    gui.ResetOnSpawn=false

    local function mk(size)
        local f=Instance.new("Frame",gui)
        f.AnchorPoint=Vector2.new(.5,.5)
        f.Position=UDim2.fromScale(.5,.5)
        f.Size=size
        f.BackgroundColor3=Color3.new(1,1,1)
        f.BorderSizePixel=0
        return f
    end

    crossV = mk(UDim2.new(0,2,0,14))
    crossH = mk(UDim2.new(0,14,0,2))

    fovCircle = mk(UDim2.new(0,fovSize,0,fovSize))
    fovCircle.BackgroundTransparency=1
    Instance.new("UICorner",fovCircle).CornerRadius=UDim.new(1,0)

    fovStroke = Instance.new("UIStroke",fovCircle)
    fovStroke.Thickness = 2
end
createFOV()

task.spawn(function()
    local h = 0
    while task.wait(0.03) do
        if fovStroke and fovCircle.Visible then
            h = (h + 2) % 360
            fovStroke.Color = Color3.fromHSV(h/360,1,1)
        end
    end
end)

