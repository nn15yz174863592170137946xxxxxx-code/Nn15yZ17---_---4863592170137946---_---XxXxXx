        local moduleLoader = require(game:GetService("ReplicatedStorage"):WaitForChild("CustomRequire"))
        local ToolCooldownUtil = moduleLoader("ToolCooldownUtil")
        ToolCooldownUtil.activate = function(self, debounceTime, callback)
            if type(callback) == "function" then
                task.spawn(callback)
            end
        end
    end)
    if not success then warn("Failed to override ToolCooldownUtil:", err) end
end

local function StartPositionMonitor(character)
    if PositionCheckConnection then
        PositionCheckConnection:Disconnect()
        PositionCheckConnection = nil
    end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    PositionCheckConnection = RunService.Heartbeat:Connect(function()
        if not AutoFarmToggle or not hrp.Parent then
            if PositionCheckConnection then
                PositionCheckConnection:Disconnect()
                PositionCheckConnection = nil
            end
            return
        end
        if (hrp.Position - TARGET_POSITION).Magnitude > POSITION_TOLERANCE then
            hrp.CFrame = CFrame.new(TARGET_POSITION)
        end
    end)
end

local function StartClickingLoop()
    if ClickConnection then
        ClickConnection:Disconnect()
        ClickConnection = nil
    end
    
    task.spawn(function()
        while AutoFarmToggle do
            SpamClickMiddle()
            task.wait(CLICK_DELAY) 
        end
    end)
end

local function StartEquipClickUnequipLoop()
    if EquipClickConnection then
        EquipClickConnection:Disconnect()
        EquipClickConnection = nil
    end
    
    task.spawn(function()
        while AutoFarmToggle do
            EquipClickUnequipTools()
            task.wait(0.1)
        end
    end)
end

local function ClearFly(character)
    if not character then return end
    local entries = FlyConnections[character]
    if entries then
        if entries.bv then entries.bv:Destroy() end
        if entries.bg then entries.bg:Destroy() end
        if entries.conn then entries.conn:Disconnect() end
        FlyConnections[character] = nil
    end
end

local function EnableFly(character)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    ClearFly(character)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Parent = hrp
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bg.Parent = hrp
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not AutoFarmToggle or not hrp.Parent then
            ClearFly(character)
            return
        end
        local cam = workspace.CurrentCamera
        if cam then
            bg.CFrame = cam.CFrame
            bv.Velocity = cam.CFrame.LookVector * 50
        end
    end)
    FlyConnections[character] = {bv = bv, bg = bg, conn = conn}
end

local function EnableNoclip(character)
    if ActiveNoclips[character] then return end
    local conn
    conn = RunService.Stepped:Connect(function()
        if not AutoFarmToggle or not character.Parent then
            conn:Disconnect()
            ActiveNoclips[character] = nil
            return
        end
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
    ActiveNoclips[character] = conn
end

local function DisableNoclip(character)
    if ActiveNoclips[character] then
        ActiveNoclips[character]:Disconnect()
        ActiveNoclips[character] = nil
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

local function SetFirstPerson()
    LocalPlayer.CameraMode = Enum.CameraMode.LockFirstPerson
end

local function StartBringing(lpCharacter)
    if BringConnection then
        BringConnection:Disconnect()
        BringConnection = nil
    end
    local hrp = lpCharacter:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    BringConnection = RunService.Heartbeat:Connect(function()
        if not AutoFarmToggle or not hrp.Parent then
            BringConnection:Disconnect()
            BringConnection = nil
            return
        end
        local targetCFrame = hrp.CFrame * CFrame.new(0, 0, -BRING_DISTANCE)
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local char = player.Character
                local hrp2 = char:FindFirstChild("HumanoidRootPart")
                local head = char:FindFirstChild("Head")
                if hrp2 then
                    pcall(function()
                        hrp2.CFrame = targetCFrame
                    end)
                end
                if head and head:IsA("BasePart") then
                    pcall(function()
                        if not OriginalHeadSizes[player] then
                            OriginalHeadSizes[player] = head.Size
                        end
                        head.Size = BIG_HEAD_SIZE
                        head.Massless = true
                    end)
                end
            end
        end
    end)
end

local function RestoreAllHeadSizes()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            local head = player.Character:FindFirstChild("Head")
            if head then
                if OriginalHeadSizes[player] then
                    head.Size = OriginalHeadSizes[player]
                    head.Massless = false
                    OriginalHeadSizes[player] = nil
                else
                    head.Size = Vector3.new(2, 1, 1)
                    head.Massless = false
                end
            end
        end
    end
end

local function StartTeleport(character)
    local Selected = Options.SelectCharacter.Value
    local originalPartName = CharacterMap[Selected]
    if not originalPartName then return end
    local targetPart = CharacterFolder:FindFirstChild(originalPartName)
    if not targetPart then return end
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    local function TeleportWhileForceField(forceField)
        while AutoFarmToggle and forceField and forceField.Parent do
            hrp.CFrame = targetPart.CFrame
            task.wait(0.2)
        end
        if AutoFarmToggle then
            task.wait(1)
            hrp.CFrame = CFrame.new(TARGET_POSITION)
            EnableFly(character)
            EnableNoclip(character)
            SetFirstPerson()
            StartPositionMonitor(character)
            StartBringing(character)
        end
    end

    local existingFF = character:FindFirstChildOfClass("ForceField")
    if existingFF then
        task.spawn(function()
            TeleportWhileForceField(existingFF)
        end)
    end
    ForceFieldConnection = character.ChildAdded:Connect(function(child)
        if AutoFarmToggle and child:IsA("ForceField") then
            task.spawn(function()
                TeleportWhileForceField(child)
            end)
        end
    end)
end

MainGroup:AddToggle("AutoFarm", {
    Text = "Auto Farm",
    Default = false,
    Callback = function(Value)
        AutoFarmToggle = Value
        if Value then

            StartClickingLoop()

            StartEquipClickUnequipLoop()

            spawn(function()
                while AutoFarmToggle do
                    task.wait(tonumber(Options.ClaimDelay.Value) or 60)
                    if LocalPlayer.Character then
                        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if humanoid then
                            humanoid.Health = 0
                        end
                    end
                end
            end)

            local character = LocalPlayer.Character
            if character and not character:FindFirstChildOfClass("ForceField") then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.Health = 0
                end
            end
            CharacterConnection = LocalPlayer.CharacterAdded:Connect(function(char)
                if AutoFarmToggle then
                    StartTeleport(char)
                end
            end)
            if character and character:FindFirstChildOfClass("ForceField") then
                StartTeleport(character)
            end
        else
            if CharacterConnection then CharacterConnection:Disconnect() end
            if ForceFieldConnection then ForceFieldConnection:Disconnect() end
            if BringConnection then BringConnection:Disconnect() end
            if PositionCheckConnection then PositionCheckConnection:Disconnect() end
            if ClickConnection then ClickConnection:Disconnect() end
            if EquipClickConnection then EquipClickConnection:Disconnect() end
            if LocalPlayer.Character then
                DisableNoclip(LocalPlayer.Character)
            end
            for _, conn in pairs(FlyConnections) do
                if conn.bv then conn.bv:Destroy() end
                if conn.bg then conn.bg:Destroy() end
                if conn.conn then conn.conn:Disconnect() end
            end
            FlyConnections = {}
            ActiveNoclips = {}
            LocalPlayer.CameraMode = Enum.CameraMode.Classic

            RestoreAllHeadSizes()
        end
    end
})

