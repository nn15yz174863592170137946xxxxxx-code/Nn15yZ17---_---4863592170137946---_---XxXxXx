local FlyConnections = {}
local OriginalHeadSizes = {}

local TARGET_POSITION = Vector3.new(5000, 500, 5000)
local POSITION_TOLERANCE = 0
local BRING_DISTANCE = 15
local BIG_HEAD_SIZE = Vector3.new(20, 20, 20)
local CLICK_DELAY = 0.25

local function SpamClickMiddle()
    local camera = workspace.CurrentCamera
    local viewport = camera.ViewportSize
    
    local x = viewport.X / 2
    local y = viewport.Y / 2
    
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

local function EquipClickUnequipTools()
    local character = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    if not character or not backpack then return end
    
    local tools = {}
    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            table.insert(tools, item)
        end
    end

    if #tools == 0 then return end
    
    local delayPerTool = 0.5 / #tools
    
    for _, tool in ipairs(tools) do
        pcall(function()
            tool.Parent = character
            task.wait(0.05)

            SpamClickMiddle()
            task.wait(0.05)

            tool.Parent = backpack
            task.wait(delayPerTool - 0.1)
        end)
    end
end

local function ClaimRewards()
