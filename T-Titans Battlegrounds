local function GetClosestDisplayName(part)
    local closestModel = nil
    local closestDistance = math.huge
    for _, model in ipairs(DisplayFolder:GetChildren()) do
        if model:IsA("Model") and model:FindFirstChild("HumanoidRootPart") then
            local distance = (model.HumanoidRootPart.Position - part.Position).Magnitude
            if distance < closestDistance then
                closestDistance = distance
                closestModel = model
            end
        end
    end
    return closestModel and closestModel.Name or part.Name
end

for _, character in ipairs(CharacterFolder:GetChildren()) do
    local success, price = pcall(function()
        return tonumber(character.PriceLabel.PriceLabel.Text)
    end)
    if success and price then
        local displayName = GetClosestDisplayName(character)
        table.insert(CharacterData, {
            Name = displayName,
            OriginalPart = character.Name,
            Price = price
        })
        CharacterMap[displayName] = character.Name
    end
end

table.sort(CharacterData, function(a, b)
    return a.Price < b.Price
end)

local CharacterNames = {}
for _, data in ipairs(CharacterData) do
    table.insert(CharacterNames, data.Name)
end

