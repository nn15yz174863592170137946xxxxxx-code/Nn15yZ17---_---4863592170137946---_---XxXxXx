-- ===== Hitbox ===== --
local HitboxGroup = Tabs.Main:AddLeftGroupbox("Hitbox","boxes")

local hitboxEnabled = false
local hitboxSize = 50
local clonedBalls = {}

local function applyHitbox(v)
    local assets = game:GetService("ReplicatedStorage"):FindFirstChild("Assets")
    if not assets then return end
    
    if v then
        for _, p in ipairs(assets:GetDescendants()) do
            if p:IsA("BasePart") then
                if p:IsDescendantOf(assets:FindFirstChild("Ball")) then
                    if not clonedBalls[p] then
                        local clone = p:Clone()
                        clone.Parent = p.Parent
                        clone.Name = p.Name .. "Part"
                        clone.Size = p.Size
                        clone.Transparency = 0
                        clone.CanCollide = false
                        
                        p.Transparency = 1
                        p.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                        
                        local weld = Instance.new("WeldConstraint")
                        weld.Part0 = p
                        weld.Part1 = clone
                        weld.Parent = clone
                        
                        clonedBalls[p] = clone
                    end
                else
                    p.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                end
            end
        end
    else
        for _, p in ipairs(assets:GetDescendants()) do
            if p:IsA("BasePart") then
                if clonedBalls[p] then
                    clonedBalls[p]:Destroy()
                    clonedBalls[p] = nil
                    p.Transparency = 0
                    p.Size = Vector3.new(2, 2, 2)
                else
                    p.Size = Vector3.new(2, 2, 2)
                end
            end
        end
    end
end

HitboxGroup:AddToggle("EnableHitbox",{
    Text = "Enable Hitbox",
    Default = false,
    Callback = function(v)
        hitboxEnabled = v
        applyHitbox(v)
    end
})

