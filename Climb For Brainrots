for _,plat in ipairs(platformList) do
	local luckyFolder = plat.Model:FindFirstChild("LuckyBlocks")
	if luckyFolder then
		local blockNames, blocks = {}, {}

		for _,b in ipairs(luckyFolder:GetChildren()) do
			if b:IsA("Model") then
				table.insert(blocks,b)
				table.insert(blockNames,b.Name)
			end
		end

		table.sort(blockNames,function(a,b)
			return tonumber(a) and tonumber(b) and tonumber(a) < tonumber(b)
		end)

		local g = Tabs.Main:AddRightGroupbox(plat.Name,"box")
		g:AddLabel(plat.Name)

		local selectedBlock
		g:AddDropdown("Block_"..plat.Name,{
			Text = "Block",
			Values = blockNames,
			Callback = function(v) selectedBlock = v end
		})

		g:AddButton("Tp", function()
			if not selectedBlock then return end
			for _,b in ipairs(blocks) do
				if b.Name == selectedBlock then
					tpTo(b:GetPivot())
					break
				end
			end
		end)

		g:AddButton("Collect", function()
			if not selectedBlock then return end
			for _,b in ipairs(blocks) do
				if b.Name == selectedBlock then
					fireAllClickDetectors(b)
					break
				end
			end
		end)

		g:AddButton("Collect All", function()
			fireAllClickDetectors(luckyFolder)
		end)
	end
end

