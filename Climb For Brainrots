local function parseCash(txt)
	local n,s = txt:lower():match("([%d%.]+)%s*([km]?)")
	n = tonumber(n)
	if not n then return end
	if s == "k" then n *= 1000 end
	if s == "m" then n *= 1000000 end
	return n
end

local function getBestEntity()
	local best,bestValue
	for _,e in ipairs(workspace.SpawnedEntities:GetChildren()) do
		local gui = e:FindFirstChild("SpawnedEntityBillboard",true)
		local cps = gui and gui:FindFirstChild("CashPerSecond",true)
		if cps then
			local val = parseCash(cps.Text)
			if val and (not bestValue or val > bestValue) then
				bestValue = val
				best = e
			end
		end
	end
	return best
end

local function fireNearestPrompt(root)
	local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local nearest,dist
	for _,p in ipairs(root:GetDescendants()) do
		if p:IsA("ProximityPrompt") and p.Parent:IsA("BasePart") then
			p.HoldDuration = 0
			p.RequiresLineOfSight = false
			local d = (p.Parent.Position - hrp.Position).Magnitude
			if d <= 30 and (not dist or d < dist) then
				dist = d
				nearest = p
			end
		end
	end
	if nearest then
		fireproximityprompt(nearest)
	end
end

RunService.Heartbeat:Connect(function()
	if not brainTP or running then return end
	running = true

	local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local target = getBestEntity()
	if not hrp or not target then
		running = false
		return
	end

	hrp.CFrame = target:GetPivot()

	local t0 = tick()
	while tick() - t0 < 0.5 do
		fireNearestPrompt(target)
		task.wait(0.1)
	end

	if originCF then
		hrp.CFrame = originCF
	end

	task.delay(COOLDOWN, function()
		running = false
	end)
end)

