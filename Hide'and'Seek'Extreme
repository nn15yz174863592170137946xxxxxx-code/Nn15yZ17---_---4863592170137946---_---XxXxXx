-- ===== attribute change handling ===== --
local function onAttributeChanged(plr)
    if plr == LocalPlayer then
        if not walkSpeedApply then
            setWalkSpeed(walkSpeedVal, false)
        end
    end
end

for _, plr in pairs(Players:GetPlayers()) do
    plr:GetAttributeChangedSignal("IsSeekerCharacter"):Connect(function()
        onAttributeChanged(plr)
    end)
end

Players.PlayerAdded:Connect(function(plr)
    plr:GetAttributeChangedSignal("IsSeekerCharacter"):Connect(function()
        onAttributeChanged(plr)
    end)
    updatePlayerDropdown()
end)

