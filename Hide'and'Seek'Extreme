-- ===== helper functions ===== --
local function isPlayerSeeker(plr)
    local char = plr.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.WalkSpeed >= 20 then
        return true
    end
    if char:FindFirstChild("ItScript") then
        return true
    end
    return false
end

local function updateESP()
    for plr, data in pairs(espObjects) do
        local char = plr.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then
            if data.gui then pcall(function() data.gui:Destroy() end) end
            if espHighlights[plr] then pcall(function() espHighlights[plr]:Destroy() end); espHighlights[plr] = nil end
            espObjects[plr] = nil
        end
    end
    if not playerESP then return end

    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
            local plr = Players:GetPlayerFromCharacter(obj)
            if plr and plr ~= LocalPlayer then
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = math.floor((Workspace.CurrentCamera.CFrame.Position - hrp.Position).Magnitude)
                    local isSeeker = isPlayerSeeker(plr)
                    local color = isSeeker and Color3.new(1,0,0) or Color3.new(1,1,1)

                    if not espObjects[plr] then
                        local gui = Instance.new("BillboardGui")
                        gui.Size = UDim2.fromOffset(300, 50)
                        gui.AlwaysOnTop = true
                        gui.StudsOffset = Vector3.new(0,3,0)
                        gui.Parent = game:GetService("CoreGui")
                        local txt = Instance.new("TextLabel", gui)
                        txt.Size = UDim2.fromScale(1,1)
                        txt.BackgroundTransparency = 1
                        txt.TextColor3 = color
                        txt.TextStrokeColor3 = Color3.new(0,0,0)
                        txt.TextStrokeTransparency = 0.3
                        txt.Font = Enum.Font.SourceSansBold
                        txt.TextSize = 20
                        txt.RichText = true
                        txt.Text = ""
                        espObjects[plr] = {gui = gui, text = txt}
                    end
                    local data = espObjects[plr]
                    data.gui.Adornee = hrp
                    data.gui.Enabled = true
                    data.text.Text = "<b>Name: " .. plr.Name .. " | Studs: " .. dist .. "</b>"
                    data.text.TextColor3 = color

                    if not espHighlights[plr] then
                        local hl = Instance.new("Highlight")
                        hl.Name = "PlayerHighlight"
                        hl.Adornee = obj
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.FillTransparency = 0.5
                        hl.OutlineTransparency = 1
                        hl.FillColor = color
                        hl.Parent = obj
                        espHighlights[plr] = hl
                    else
                        espHighlights[plr].Adornee = obj
                        espHighlights[plr].Enabled = true
                        espHighlights[plr].FillColor = color
                    end
                end
            end
        end
    end
end

-- ===== HITBOX FUNCTIONS ===== --
local function applyHitboxToPlayer(plr, size)
    if plr == LocalPlayer then return end
    local char = plr.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    if not originalHeadSizes[plr] then
        originalHeadSizes[plr] = head.Size
    end

    head.Size = Vector3.new(size, size, size)
    head.Transparency = 0.8
    head.Massless = true
    head.CanCollide = false
end

local function restoreHitboxForPlayer(plr)
    local char = plr.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    if originalHeadSizes[plr] then
        head.Size = originalHeadSizes[plr]
        head.Transparency = 0
        head.Massless = false
        head.CanCollide = true
    end
    originalHeadSizes[plr] = nil
end

local function applyHitboxToAll(size)
    for _, plr in pairs(Players:GetPlayers()) do
        applyHitboxToPlayer(plr, size)
    end
end

local function restoreHitboxForAll()
    for plr in pairs(originalHeadSizes) do
        restoreHitboxForPlayer(plr)
    end
    originalHeadSizes = {}
end

local function startHitboxMaintain()
    if hitboxMaintainConnection then return end
    hitboxMaintainConnection = RunService.Heartbeat:Connect(function()
        if not hitboxApply then return end
        for plr in pairs(originalHeadSizes) do
            local char = plr.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    head.CanCollide = false
                end
            end
        end
    end)
end

local function stopHitboxMaintain()
    if hitboxMaintainConnection then
        hitboxMaintainConnection:Disconnect()
        hitboxMaintainConnection = nil
    end
end

-- ===== walk/jump functions ===== --
local function setWalkSpeed(val, apply)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if apply then
        hum.WalkSpeed = val
    else
        local isSeeker = isPlayerSeeker(LocalPlayer)
        hum.WalkSpeed = isSeeker and 20 or 16
    end
end

local function setJumpPower(val, apply)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if apply then
        hum.JumpPower = val
    else
        hum.JumpPower = 55
    end
end

