local function updatePlayerDropdown()
    local names = {}
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(names, plr.Name)
        end
    end
    table.sort(names)
    playerDropdown:SetValues(names)
end

Players.PlayerAdded:Connect(updatePlayerDropdown)
Players.PlayerRemoving:Connect(updatePlayerDropdown)
updatePlayerDropdown()

local originalPositions = {}

TeleportGroup:AddButton("Bring Player", function()
    local selected = playerDropdown.Value
    if not selected then return end
    local target = Players:FindFirstChild(selected)
    if not target then return end
    local char = target.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local localChar = LocalPlayer.Character
    if not localChar then return end
    local localHrp = localChar:FindFirstChild("HumanoidRootPart")
    if not localHrp then return end

    originalPositions[target] = hrp.CFrame

    hrp.CFrame = localHrp.CFrame + Vector3.new(0, 3, 0)

    task.spawn(function()
        task.wait(1)
        if originalPositions[target] and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            target.Character.HumanoidRootPart.CFrame = originalPositions[target]
        end
        originalPositions[target] = nil
    end)
end)

TeleportGroup:AddButton("Bring All Players", function()
    local localChar = LocalPlayer.Character
    if not localChar then return end
    local localHrp = localChar:FindFirstChild("HumanoidRootPart")
    if not localHrp then return end

    local playersToBring = {}
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    table.insert(playersToBring, {plr = plr, hrp = hrp, orig = hrp.CFrame})
                end
            end
        end
    end

    for _, data in ipairs(playersToBring) do
        data.hrp.CFrame = localHrp.CFrame + Vector3.new(0, 3, 0)
        originalPositions[data.plr] = data.orig
    end

    task.spawn(function()
        task.wait(1)
        for _, data in ipairs(playersToBring) do
            if originalPositions[data.plr] and data.plr.Character and data.plr.Character:FindFirstChild("HumanoidRootPart") then
                data.plr.Character.HumanoidRootPart.CFrame = originalPositions[data.plr]
            end
            originalPositions[data.plr] = nil
        end
    end)
end)

TeleportGroup:AddLabel("Farm infinite Credits or help Seeker by bringing them to you with loop bring", true)

local loopBringEnabled = false
local loopBringThread = nil

TeleportGroup:AddToggle("LoopBringPlayer", {
    Text = "Loop Bring Selected Player",
    Default = false,
    Callback = function(v)
        loopBringEnabled = v
        if v then
            if loopBringThread then task.cancel(loopBringThread) end
            loopBringThread = task.spawn(function()
                while loopBringEnabled do
                    local selected = playerDropdown.Value
                    if selected then
                        local target = Players:FindFirstChild(selected)
                        if target then
                            local char = target.Character
                            if char then
                                local hrp = char:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    local localChar = LocalPlayer.Character
                                    if localChar then
                                        local localHrp = localChar:FindFirstChild("HumanoidRootPart")
                                        if localHrp then
                                            local orig = hrp.CFrame
                                            hrp.CFrame = localHrp.CFrame + Vector3.new(0, 3, 0)
                                            task.wait(0.1)
                                            if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                                                target.Character.HumanoidRootPart.CFrame = orig
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        else
            if loopBringThread then
                task.cancel(loopBringThread)
                loopBringThread = nil
            end
        end
    end
})

