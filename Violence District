-- ===== Survivors ===== --
local SurvivorGroup = Tabs.Main:AddLeftGroupbox("Survivors","user")

local AutoEscape = false
SurvivorGroup:AddToggle("Auto escape",{
    Text = "Auto escape",
    Default = false,
    Callback = function(v)
        AutoEscape = v
        task.spawn(function()
            while AutoEscape do
                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, part in ipairs(workspace.Map:GetDescendants()) do
                        if part:IsA("BasePart") and (part.Position - hrp.Position).Magnitude <= 1000 then
                            pcall(function()
                                firetouchinterest(hrp, part, 0)
                                firetouchinterest(hrp, part, 1)
                            end)
                        end
                    end
                end
                task.wait(1)
            end
        end)
    end
})

local AntiFailGenerator = false
SurvivorGroup:AddToggle("Anti fail",{
    Text = "Anti fail",
    Default = false,
    Callback = function(v)
        AntiFailGenerator = v
    end
})

local AutoPerfectGenerator = false
SurvivorGroup:AddToggle("Auto perfect",{
    Text = "Auto perfect",
    Default = false,
    Callback = function(v)
        AutoPerfectGenerator = v
        task.spawn(function()
            while AutoPerfectGenerator do
                for i = 1,4 do
                    pcall(function()
                        ReplicatedStorage.Remotes.Generator.SkillCheckResultEvent:FireServer(
                            "success",
                            1,
                            workspace.Map:FindFirstChildWhichIsA("Model", true),
                            workspace.Map:FindFirstChild("GeneratorPoint"..i, true)
                        )
                    end)
                end
                task.wait(0.1)
            end
        end)
    end
})

-- ===== Killer ===== --
local KillerGroup = Tabs.Main:AddRightGroupbox("Killer","skull")
local AntiBlind = false
KillerGroup:AddToggle("Anti blind",{
    Text = "Anti blind",
    Default = false,
    Callback = function(v)
        AntiBlind = v
    end
})

-- ===== Remote Block ===== --
local oldFire
oldFire = hookmetamethod(game,"__namecall",function(self,...)
    local args = {...}
    if tostring(self) == "SkillCheckResultEvent" then
        if AntiFailGenerator and (args[1] == "fail" or args[1] == "neutral") then
            return nil
        end
    end
    if AntiBlind and tostring(self) == "GotBlinded" then
        return nil
    end
    return oldFire(self,...)
end)

