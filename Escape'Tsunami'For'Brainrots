        autoSellEnabled = v
        if autoSellConnection then autoSellConnection:Disconnect(); autoSellConnection = nil end
        if v then
            autoSellConnection = RunService.Heartbeat:Connect(function()
                if not autoSellEnabled then return end
                local threshold = tonumber(sellThreshold.Value) or 0
                local character = LocalPlayer.Character
                local backpack = LocalPlayer:FindFirstChild("Backpack")
                if not character or not backpack then return end
                for _, tool in ipairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        local level = tool:GetAttribute("Level")
                        if level and level < threshold then
                            pcall(function() game:GetService("ReplicatedStorage"):WaitForChild("RemoteFunctions"):WaitForChild("SellTool"):InvokeServer() end)
                            return
                        end
                    end
                end
                for _, tool in ipairs(backpack:GetChildren()) do
                    if tool:IsA("Tool") then
                        local level = tool:GetAttribute("Level")
                        if level and level < threshold then
                            tool.Parent = character
                            return
                        end
                    end
                end
            end)
        end
    end
})

