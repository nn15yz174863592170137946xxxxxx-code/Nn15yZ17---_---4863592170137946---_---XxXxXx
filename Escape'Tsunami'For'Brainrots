-- ===== TOUCH TRANSMITTER CONTROL ===== --
local touchMaintainConnection = nil

local function disableAllTouch()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj:FindFirstChildOfClass("TouchTransmitter") then
            obj.CanTouch = false
        end
    end
end

local function enableAllTouch()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj:FindFirstChildOfClass("TouchTransmitter") then
            obj.CanTouch = true
        end
    end
end

local function startTouchMaintain()
    if touchMaintainConnection then return end
    touchMaintainConnection = RunService.Heartbeat:Connect(function()
        if not (brainrotEnabled or luckyEnabled) then return end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj:FindFirstChildOfClass("TouchTransmitter") and obj.CanTouch then
                obj.CanTouch = false
            end
        end
    end)
end

local function stopTouchMaintain()
    if touchMaintainConnection then
        touchMaintainConnection:Disconnect()
        touchMaintainConnection = nil
    end
end

-- ===== farm loop ===== --
local function onCharacterAdded()
    if farmThread then task.cancel(farmThread); farmThread = nil end
    if yConnection then yConnection:Disconnect(); yConnection = nil end
    disableNoclip()
    Workspace.Gravity = defaultGravity
    if brainrotEnabled or luckyEnabled then
        task.wait(1)
        startFarm()
    end
end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

local function farmLoop()
    while farmRunning do
        local character = LocalPlayer.Character
        if not character then character = LocalPlayer.CharacterAdded:Wait() end
        local hrp = character:WaitForChild("HumanoidRootPart")
        farmStartPos = hrp.Position  -- store start position for this cycle
        local startPos = hrp.Position
        local collected = 0
        local collectedObjects = {}
        local maxCarry = LocalPlayer:GetAttribute("MaxCarry") or 1
        if maxCarry < 1 then maxCarry = 1 end
        local currentY = nil
        local died = false

        yConnection = RunService.Heartbeat:Connect(function()
            if currentY and farmRunning then
                hrp.CFrame = CFrame.new(hrp.Position.X, currentY, hrp.Position.Z)
            end
        end)

        local function checkDeath()
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then
                return true
            end
            return false
        end

        local function snapToHeight(targetGapY)
            currentY = targetGapY
            hrp.CFrame = CFrame.new(hrp.Position.X, targetGapY, hrp.Position.Z)
        end

        local function tweenToPos(targetPos)
            local dist = (hrp.Position - targetPos).Magnitude
            if dist < 1 then return end
            local targetWithGapY = Vector3.new(targetPos.X, currentY, targetPos.Z)
            local tween = TweenService:Create(hrp, TweenInfo.new(dist / getTweenSpeed(), Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(targetWithGapY)
            })
            tween:Play()
            tween.Completed:Wait()
            hrp.CFrame = CFrame.new(targetWithGapY)
        end

        local function firePromptsAt(pos)
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local parent = obj.Parent
                    if parent and parent:IsA("BasePart") and (parent.Position - pos).Magnitude <= 10 then
                        obj.HoldDuration = 0
                        task.wait(0.05)
                        fireproximityprompt(obj)
                    end
                end
            end
        end

        local function getAllBrainrotPositions()
            local positions = {}
            local activeBrainrots = workspace:FindFirstChild("ActiveBrainrots")
            if not activeBrainrots then return positions end
            for _, section in pairs(activeBrainrots:GetChildren()) do
                for _, brainrot in pairs(section:GetChildren()) do
                    if brainrot:IsA("Model") and brainrot.Parent then
                        local pos = brainrot:GetPivot().Position
                        local level = brainrot:GetAttribute("Level") or 0
                        table.insert(positions, {Position = pos, Object = brainrot, Level = level, Type = "brainrot"})
                    end
                end
            end
            return positions
        end

        local function getAllLuckyBlockPositions()
            local positions = {}
            local activeLuckyBlocks = workspace:FindFirstChild("ActiveLuckyBlocks")
            if not activeLuckyBlocks then return positions end
            for _, luckyBlock in pairs(activeLuckyBlocks:GetChildren()) do
                if luckyBlock:IsA("Model") and luckyBlock.Parent then
                    local pos = luckyBlock:GetPivot().Position
                    local level = luckyBlock:GetAttribute("Level") or 0
                    table.insert(positions, {Position = pos, Object = luckyBlock, Level = level, Type = "lucky"})
                end
            end
            return positions
        end

        local function findBestTarget()
            local candidates = {}
            if brainrotEnabled then
                local br = getAllBrainrotPositions()
                for _, v in ipairs(br) do table.insert(candidates, v) end
            end
            if luckyEnabled then
                local lb = getAllLuckyBlockPositions()
                for _, v in ipairs(lb) do table.insert(candidates, v) end
            end
            local available = {}
            for _, cand in ipairs(candidates) do
                local excluded = false
                for _, obj in ipairs(collectedObjects) do
                    if obj == cand.Object then
                        excluded = true
                        break
                    end
                end
                if not excluded then
                    table.insert(available, cand)
                end
            end
            if #available == 0 then return nil, nil end

            local maxLevel = -math.huge
            for _, cand in ipairs(available) do
                if cand.Level > maxLevel then
                    maxLevel = cand.Level
                end
            end
            local bestLevel = {}
            for _, cand in ipairs(available) do
                if cand.Level == maxLevel then
                    table.insert(bestLevel, cand)
                end
            end
            if #bestLevel == 1 then
                return bestLevel[1].Object, bestLevel[1].Position
            end
            local farthest, farthestPos = nil, nil
            local maxDist = -math.huge
            for _, cand in ipairs(bestLevel) do
                local dist = (startPos - cand.Position).Magnitude
                if dist > maxDist then
                    maxDist = dist
                    farthest = cand.Object
                    farthestPos = cand.Position
                end
            end
            return farthest, farthestPos
        end

        enableNoclip()
        Workspace.Gravity = zeroGravity

        local startGap = findClosestGap(hrp.Position)
        snapToHeight(startGap.Y)

        while farmRunning and collected < maxCarry do
            if checkDeath() then
                died = true
                break
            end

            local targetObj, targetPos = findBestTarget()
            if not targetObj then
                task.wait(1)
                break
            end

            local targetGap = findClosestGap(targetPos)
            snapToHeight(targetGap.Y)

            tweenToPos(targetPos)

            if checkDeath() then
                died = true
                break
            end

            local pauseStart = tick()
            while tick() - pauseStart < 1 and farmRunning do
                if checkDeath() then
                    died = true
                    break
                end
                task.wait(0.05)
            end

            if died then break end

            firePromptsAt(targetPos)

            table.insert(collectedObjects, targetObj)
            collected = collected + 1
        end

        if not died and farmRunning then
            tweenToPos(startPos)
            snapToHeight(startPos.Y)
        end

        if yConnection then
            yConnection:Disconnect()
            yConnection = nil
        end

        if died then
            while not LocalPlayer.Character do
                task.wait(1)
            end
        end

        task.wait(0.5)
    end

    if yConnection then
        yConnection:Disconnect()
        yConnection = nil
    end
    disableNoclip()
    Workspace.Gravity = defaultGravity
    farmThread = nil
end

local function startFarm()
    if farmThread then return end
    startTouchMaintain()
    farmRunning = true
    farmThread = task.spawn(farmLoop)
end

local function stopFarm()
    farmRunning = false
    if farmThread then
        task.cancel(farmThread)
        farmThread = nil
    end
    if yConnection then
        yConnection:Disconnect()
        yConnection = nil
    end
    disableNoclip()
    Workspace.Gravity = defaultGravity

    -- Wait for player to return to start position before re-enabling touch
    task.spawn(function()
        if farmStartPos then
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    while hrp and (hrp.Position - farmStartPos).Magnitude > 5 do
                        task.wait(0.1)
                    end
                end
            end
        end
        stopTouchMaintain()
        enableAllTouch()
    end)
end

