local function getTowerPosition()
    local success, result = pcall(function()
        local promptPart = workspace:FindFirstChild("GameObjects")
            and workspace.GameObjects:FindFirstChild("PlaceSpecific")
            and workspace.GameObjects.PlaceSpecific:FindFirstChild("root")
            and workspace.GameObjects.PlaceSpecific.root:FindFirstChild("Tower")
            and workspace.GameObjects.PlaceSpecific.root.Tower:FindFirstChild("Main")
            and workspace.GameObjects.PlaceSpecific.root.Tower.Main:FindFirstChild("Prompt")
        if not promptPart then return nil end
        local worldCFrame = promptPart:GetAttribute("WorldCFrame")
        if not worldCFrame then return nil end
        return worldCFrame.Position
    end)
    if success then
        return result
    end
    return nil
end

TowerGroup:AddToggle("AutoTower", {
    Text = "Auto Tower",
    Default = false,
    Callback = function(v)
        autoTowerEnabled = v
        if v then
            if farmRunning then stopFarm() end
            if autoTowerThread then task.cancel(autoTowerThread) end
            autoTowerThread = task.spawn(function()
                while autoTowerEnabled do
                    local char = LocalPlayer.Character
                    if not char then task.wait(1) continue end
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait(1) continue end
                    local targetPos = getTowerPosition()
                    if not targetPos then task.wait(2) continue end
                    local gap = findClosestGap(targetPos)
                    if not gap then task.wait(1) continue end
                    snapToHeight(hrp, gap.Y)
                    local currentY = gap.Y
                    tweenToPosXZ(hrp, targetPos, currentY)
                    local promptPart = workspace:FindFirstChild("GameObjects")
                        and workspace.GameObjects:FindFirstChild("PlaceSpecific")
                        and workspace.GameObjects.PlaceSpecific:FindFirstChild("root")
                        and workspace.GameObjects.PlaceSpecific.root:FindFirstChild("Tower")
                        and workspace.GameObjects.PlaceSpecific.root.Tower:FindFirstChild("Main")
                        and workspace.GameObjects.PlaceSpecific.root.Tower.Main:FindFirstChild("Prompt")
                    if promptPart then
                        local prompt = promptPart:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then
                            prompt.HoldDuration = 0
                            fireproximityprompt(prompt)
                        end
                    end
                    task.wait(2)
                end
            end)
        else
            if autoTowerThread then task.cancel(autoTowerThread) end
        end
    end
})

-- ===== shared variables and helpers ===== --
local defaultGravity = Workspace.Gravity
local zeroGravity = 0
local noclipConnection = nil

local function enableNoclip()
    if noclipConnection then return end
    noclipConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    local char = LocalPlayer.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

local function findFolder(name)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Folder") and obj.Name == name then
            return obj
        end
    end
    return nil
end

local gapsFolder = findFolder("Gaps")
local gaps = {}
if gapsFolder then
    for _, child in pairs(gapsFolder:GetChildren()) do
        if child:IsA("Model") then
            local pos = child:GetPivot().Position
            table.insert(gaps, {Position = pos, Y = pos.Y})
        end
    end
end

if #gaps == 0 then
    MainGroup:AddLabel("No gaps found!")
end

table.sort(gaps, function(a, b)
    return a.Position.X < b.Position.X
end)

local function getTweenSpeed()
    return (LocalPlayer:GetAttribute("CurrentSpeed") or 16) * 3
end

local function findClosestGap(pos)
    local closestGap = gaps[1]
    local closestDist = (pos - gaps[1].Position).Magnitude
    for i = 2, #gaps do
        local dist = (pos - gaps[i].Position).Magnitude
        if dist < closestDist then
            closestDist = dist
            closestGap = gaps[i]
        end
    end
    return closestGap
end

