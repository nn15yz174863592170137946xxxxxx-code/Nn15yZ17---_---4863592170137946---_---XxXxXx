local originalHoldDurations = {}

MainGroup:AddToggle("InstantInteract", {
    Text = "Instant Interact",
    Default = false,
    Callback = function(v)
        instantInteractEnabled = v
        if v then
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    originalHoldDurations[obj] = obj.HoldDuration
                    obj.HoldDuration = 0
                end
            end
            instantInteractConnection = workspace.DescendantAdded:Connect(function(obj)
                if instantInteractEnabled and obj:IsA("ProximityPrompt") then
                    originalHoldDurations[obj] = obj.HoldDuration
                    obj.HoldDuration = 0
                end
            end)
            Library:Notify("Instant Interact Enabled", 3)
        else
            for obj, originalValue in pairs(originalHoldDurations) do
                if obj and obj.Parent then
                    obj.HoldDuration = originalValue
                end
            end
            originalHoldDurations = {}
            if instantInteractConnection then
                instantInteractConnection:Disconnect()
                instantInteractConnection = nil
            end
            Library:Notify("Instant Interact Disabled", 3)
        end
    end
})

