local function getPlayerStatus(plr)
    local char = plr.Character
    if not char then return "Normal", Color3.new(1,1,1) end
    if char:FindFirstChild("Ghost") then
        return "Ghost", Color3.new(0,1,1)
    end
    for _, obj in pairs(char:GetDescendants()) do
        if obj:IsA("TouchTransmitter") then
            return "Piggy", Color3.new(1,0,0)
        end
    end
    local backpack = plr:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name == "Knife" then
                return "Traitor", Color3.new(1,0,0)
            end
        end
    end
    return "Normal", Color3.new(1,1,1)
end

local function updatePlayerESP()
    for plr, data in pairs(playerESPObjects) do
        local char = plr.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then
            if data.gui then pcall(function() data.gui:Destroy() end) end
            if playerHighlights[plr] then pcall(function() playerHighlights[plr]:Destroy() end) end
            playerESPObjects[plr] = nil
            playerHighlights[plr] = nil
        end
    end
    if not playerESP then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then continue end
        local dist = math.floor((cam.CFrame.Position - hrp.Position).Magnitude)
        local status, color = getPlayerStatus(plr)
        if not playerESPObjects[plr] then
            local gui = Instance.new("BillboardGui")
            gui.Size = UDim2.fromOffset(300, 50)
            gui.AlwaysOnTop = true
            gui.StudsOffset = Vector3.new(0,3,0)
            gui.Parent = game:GetService("CoreGui")
            local txt = Instance.new("TextLabel", gui)
            txt.Size = UDim2.fromScale(1,1)
            txt.BackgroundTransparency = 1
            txt.TextColor3 = color
            txt.TextStrokeColor3 = Color3.new(0,0,0)
            txt.TextStrokeTransparency = 0.3
            txt.Font = Enum.Font.SourceSansBold
            txt.TextSize = 20
            txt.RichText = true
            txt.Text = ""
            playerESPObjects[plr] = {gui = gui, text = txt}
        end
        local data = playerESPObjects[plr]
        data.gui.Adornee = hrp
        data.gui.Enabled = true
        data.text.Text = "<b>Name: " .. plr.Name .. " | " .. status .. " | Studs: " .. dist .. "</b>"
        data.text.TextColor3 = color
        if not playerHighlights[plr] then
            local hl = Instance.new("Highlight")
            hl.Name = "PlayerHighlight"
            hl.Adornee = char
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillTransparency = 0.5
            hl.OutlineTransparency = 1
            hl.FillColor = color
            hl.Parent = char
            playerHighlights[plr] = hl
        else
            playerHighlights[plr].Adornee = char
            playerHighlights[plr].Enabled = true
            playerHighlights[plr].FillColor = color
        end
    end
end

local function updatePiggyESP()
    for obj, data in pairs(piggyESPObjects) do
        if not obj or not obj.Parent then
            if data.gui then pcall(function() data.gui:Destroy() end) end
            if piggyHighlights[obj] then pcall(function() piggyHighlights[obj]:Destroy() end) end
            piggyESPObjects[obj] = nil
            piggyHighlights[obj] = nil
        end
    end
    if not piggyESP then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
            local hasTool = false
            for _, descendant in pairs(obj:GetDescendants()) do
                if descendant.Name == "ToolRequired" then
                    hasTool = true
                    break
                end
            end
            local subModels = {}
            for _, descendant in pairs(obj:GetDescendants()) do
                if descendant:IsA("Model") and descendant ~= obj then
                    table.insert(subModels, descendant)
                end
            end
            local touchInModel = false
            local touchOutside = false
            for _, descendant in pairs(obj:GetDescendants()) do
                if descendant:IsA("TouchTransmitter") then
                    local inModel = false
                    for _, model in ipairs(subModels) do
                        if descendant:IsDescendantOf(model) then
                            inModel = true
                            break
                        end
                    end
                    if inModel then
                        touchInModel = true
                    else
                        touchOutside = true
                    end
                end
            end
            local hasAnyTouch = touchInModel or touchOutside
            if hasTool or hasAnyTouch then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")
                if hrp then
                    local displayName = obj.Name
                    if obj.Name:match("^-?%d+$") then displayName = "" end
                    local color = Color3.new(1,0,0)
                    if hasTool or touchInModel then
                        color = Color3.new(0,1,0)
                    end
                    if not piggyESPObjects[obj] then
                        local gui = Instance.new("BillboardGui")
                        gui.Size = UDim2.fromOffset(300, 50)
                        gui.AlwaysOnTop = true
                        gui.StudsOffset = Vector3.new(0,3,0)
                        gui.Parent = game:GetService("CoreGui")
                        local txt = Instance.new("TextLabel", gui)
                        txt.Size = UDim2.fromScale(1,1)
                        txt.BackgroundTransparency = 1
                        txt.TextColor3 = color
                        txt.TextStrokeColor3 = Color3.new(0,0,0)
                        txt.TextStrokeTransparency = 0.3
                        txt.Font = Enum.Font.SourceSansBold
                        txt.TextSize = 20
                        txt.RichText = true
                        txt.Text = ""
                        piggyESPObjects[obj] = {gui = gui, text = txt}
                    end
                    local data = piggyESPObjects[obj]
                    local dist = math.floor((cam.CFrame.Position - hrp.Position).Magnitude)
                    data.gui.Adornee = hrp
                    data.gui.Enabled = true
                    if displayName == "" then
                        data.text.Text = "<b>" .. dist .. " studs</b>"
                    else
                        data.text.Text = "<b>" .. displayName .. " | " .. dist .. " studs</b>"
                    end
                    data.text.TextColor3 = color
                    if not piggyHighlights[obj] then
                        local hl = Instance.new("Highlight")
                        hl.Name = "PiggyHighlight"
                        hl.Adornee = obj
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.FillTransparency = 0.5
                        hl.OutlineTransparency = 1
                        hl.FillColor = color
                        hl.Parent = obj
                        piggyHighlights[obj] = hl
                    else
                        piggyHighlights[obj].Adornee = obj
                        piggyHighlights[obj].Enabled = true
                        piggyHighlights[obj].FillColor = color
                    end
                end
            else
                if piggyESPObjects[obj] then
                    piggyESPObjects[obj].gui.Enabled = false
                end
                if piggyHighlights[obj] then
                    piggyHighlights[obj].Enabled = false
                end
            end
        end
    end
end

local function updateItemESP()
    for part, data in pairs(itemHighlights) do
        if not part or not part.Parent then
            if data.gui then pcall(function() data.gui:Destroy() end) end
            if data.highlight then pcall(function() data.highlight:Destroy() end) end
            itemHighlights[part] = nil
        end
    end
    if not itemESP then
        for _, data in pairs(itemHighlights) do
            if data.gui then pcall(function() data.gui:Destroy() end) end
            if data.highlight then pcall(function() data.highlight:Destroy() end) end
        end
        itemHighlights = {}
        return
    end
    local folder = findItemFolder()
    if not folder then return end
    for _, part in pairs(folder:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "" then
            if not itemHighlights[part] then
                local gui = Instance.new("BillboardGui")
                gui.Size = UDim2.fromOffset(200, 40)
                gui.AlwaysOnTop = true
                gui.StudsOffset = Vector3.new(0,2,0)
                gui.Parent = game:GetService("CoreGui")
                local txt = Instance.new("TextLabel", gui)
                txt.Size = UDim2.fromScale(1,1)
                txt.BackgroundTransparency = 1
                txt.TextColor3 = getItemColor(part)
                txt.TextStrokeColor3 = Color3.new(0,0,0)
                txt.TextStrokeTransparency = 0.3
                txt.Font = Enum.Font.SourceSansBold
                txt.TextSize = 18
                txt.RichText = true
                txt.Text = ""
                
                local hl = Instance.new("Highlight")
                hl.Name = "ItemHighlight"
                hl.Adornee = part
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.FillTransparency = 0
                hl.OutlineTransparency = 1
                hl.FillColor = getItemColor(part)
                hl.Parent = part
                
                itemHighlights[part] = {gui = gui, text = txt, highlight = hl}
            else
                local data = itemHighlights[part]
                data.gui.Adornee = part
                data.gui.Enabled = true
                local dist = math.floor((cam.CFrame.Position - part.Position).Magnitude)
                if part.Name:match("^-?%d+$") then
                    data.text.Text = "<b>" .. dist .. " studs</b>"
                else
                    data.text.Text = "<b>" .. part.Name .. " | " .. dist .. " studs</b>"
                end
                data.text.TextColor3 = getItemColor(part)
                data.highlight.Adornee = part
                data.highlight.Enabled = true
                data.highlight.FillColor = getItemColor(part)
            end
        end
    end
end

