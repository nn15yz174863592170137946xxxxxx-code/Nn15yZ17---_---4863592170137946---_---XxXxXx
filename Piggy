local itemPartsTable = {}
local function updateItemDropdown()
    local folder = findItemFolder()
    if not folder then
        Options.ItemDropdown:SetValues({ "No folder found" })
        return
    end
    local itemNames = {}
    itemPartsTable = {}
    for _, part in pairs(folder:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "" then
            local displayName
            if part.Name:match("^-?%d+$") then
                if part.BrickColor then
                    displayName = part.BrickColor.Name
                else
                    local color = getItemColor(part)
                    displayName = colorToRGBString(color)
                end
            else
                displayName = part.Name
            end
            local baseDisplay = displayName
            local count = 1
            while itemPartsTable[displayName] do
                displayName = baseDisplay .. " (" .. count .. ")"
                count = count + 1
            end
            table.insert(itemNames, displayName)
            itemPartsTable[displayName] = part
        end
    end
    table.sort(itemNames)
    if #itemNames == 0 then
        Options.ItemDropdown:SetValues({ "No items" })
    else
        Options.ItemDropdown:SetValues(itemNames)
    end
end

