local function getMaxCapacity(toolName)
if toolName == "Light Ammo" or toolName == "Medium Ammo" or toolName == "Shotgun Ammo" then
return 5000
end
return 999
end

local function getOwnedSafe()
local storages = workspace:FindFirstChild("Storages")
if not storages then return nil end
for _, storage in ipairs(storages:GetChildren()) do
local owner = storage:GetAttribute("Owner")
if owner == LocalPlayer.Name then
local contents = storage:FindFirstChild("Contents")
if contents then
local objects = contents:FindFirstChild("Objects")
if objects then
local safe = objects:FindFirstChild("Safe")
if safe then return safe end
end
end
end
end
return nil
end

local function getBankSlots()
local bankGui = LocalPlayer.PlayerGui:FindFirstChild("HUD")
if not bankGui then return {} end
local bank = bankGui:FindFirstChild("Bank")
if not bank then return {} end
local grid = bank:FindFirstChild("Grid")
if not grid then return {} end

local slots = {}  
for _, child in ipairs(grid:GetChildren()) do  
    local num = tonumber(child.Name)  
    if num then  
        slots[num] = child  
    end  
end  
  
local sorted = {}  
for i = 1, #slots do  
    if slots[i] then  
        table.insert(sorted, {number = i, frame = slots[i]})  
    end  
end  
return sorted

end

local function getItemNameFromSlot(slotFrame)
local label = slotFrame:FindFirstChild("ItemName")
if not label then return nil end
local text = label.Text
if text == "NOTHING" or text == "" then return nil end
local name = text:match("^([^%(]*)")
if name then
return name:gsub("%s+$", "")
end
return nil
end

local function getItemQuantity(slotFrame)
local label = slotFrame:FindFirstChild("ItemName")
if not label then return 0 end
local text = label.Text
local startPos = text:find("%(")
local endPos = text:find("%)")
if startPos and endPos then
local numStr = text:sub(startPos + 1, endPos - 1)
numStr = numStr:gsub("^[xX]", "")
return tonumber(numStr) or 0
end
return 0
end

local function findToolInInventory(toolName)
local backpack = LocalPlayer.Backpack
local character = LocalPlayer.Character

if backpack then  
    for _, tool in ipairs(backpack:GetChildren()) do  
        local name = tool.Name  
        if name:find("%[x%d+%]") then  
            name = name:match("^(.-)%s*%[x%d+%]")  
        end  
        if name == toolName then  
            local qty = tool.Name:match("%[x(%d+)%]")  
            return tool, qty and tonumber(qty) or 1  
        end  
    end  
end  
  
if character then  
    for _, tool in ipairs(character:GetChildren()) do  
        if tool:IsA("Tool") then  
            local name = tool.Name  
            if name:find("%[x%d+%]") then  
                name = name:match("^(.-)%s*%[x%d+%]")  
            end  
            if name == toolName then  
                local qty = tool.Name:match("%[x(%d+)%]")  
                return tool, qty and tonumber(qty) or 1  
            end  
        end  
    end  
end  
  
return nil, 0

end

local function storeUnit(slotNumber, amount, safe)
local remote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("RemoteEvent")
local args = {
"StoreBank",
tostring(slotNumber),
tostring(amount),
safe
}
remote:FireServer(unpack(args))
end
local function equipOnlyThisTool(tool)
local char = LocalPlayer.Character
local backpack = LocalPlayer.Backpack
if not char or not backpack or not tool then return false end

local humanoid = char:FindFirstChildOfClass("Humanoid")  
if humanoid then  
    humanoid:UnequipTools()  
end  

for _, obj in ipairs(char:GetChildren()) do  
    if obj:IsA("Tool") and obj ~= tool then  
        obj.Parent = backpack  
    end  
end  

if tool.Parent ~= char then  
    tool.Parent = char  
end  

task.wait(0.1)  
return true

end

local function processTool(toolName, safe, slots)
local tool, quantity = findToolInInventory(toolName)
if not tool or quantity == 0 then return false end

local maxCap = getMaxCapacity(toolName)  
local targetSlot = nil  
local availableRoom = 0  
  
for _, slot in ipairs(slots) do  
    local item = getItemNameFromSlot(slot.frame)  
    if item == toolName then  
        local currentQty = getItemQuantity(slot.frame)  
        local room = maxCap - currentQty  
        if room > 0 and room > availableRoom then  
            availableRoom = room  
            targetSlot = slot  
        end  
    end  
end  
  
if not targetSlot then  
    for _, slot in ipairs(slots) do  
        local item = getItemNameFromSlot(slot.frame)  
        if item == nil then  
            targetSlot = slot  
            availableRoom = maxCap  
            break  
        end  
    end  
end  
  
if not targetSlot then  
    Library:Notify("No space in bank for " .. toolName, 3)  
    return false  
end  
  
local storeAmount = math.min(quantity, availableRoom)  
if storeAmount <= 0 then return false end  
  
local char = LocalPlayer.Character  
local hrp = char and char:FindFirstChild("HumanoidRootPart")  
local startPos = hrp and hrp.CFrame or nil  
  
if hrp and safe then  
    local safePart = safe:FindFirstChildWhichIsA("BasePart") or safe  
    hrp.CFrame = CFrame.new(safePart.Position) + Vector3.new(0, 3, 0)  
    task.wait(0.5)  
end  
  
equipOnlyThisTool(tool)  
  
storeUnit(targetSlot.number, storeAmount, safe)  
task.wait(0.5)  
  
if startPos and hrp then  
    hrp.CFrame = startPos  
end  
  
Library:Notify("Stored " .. storeAmount .. "x " .. toolName, 1)  
return true

end

