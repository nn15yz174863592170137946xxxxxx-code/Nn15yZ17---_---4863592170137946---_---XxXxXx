-- ===== SAFETY CHECK ===== --
local function isUnsafe(pos)
    if workspace:FindFirstChild("Live") then
        for _,p in ipairs(workspace.Live:GetChildren()) do
            local hrp = p:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - pos).Magnitude <= SAFE_RADIUS then
                return true
            end
        end
    end

    if workspace:FindFirstChild("Mobs") then
        for _,m in ipairs(workspace.Mobs:GetChildren()) do
            local part = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChildWhichIsA("BasePart")
            if part and (part.Position - pos).Magnitude <= SAFE_RADIUS then
                return true
            end
        end
    end

    return false
end

-- ===== AUTOFARM LOGIC ===== --
local LOOK_DOWN = CFrame.Angles(math.rad(-90),0,0)

local function runAutofarm(getStorages)
    if isBuying or isStoring then return end

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local startCF = hrp.CFrame
    local storages = getStorages()
    local lastStorage

    local function getNearest()
        local best,dist=nil,math.huge
        for _,v in ipairs(storages) do
            if v~=lastStorage
            and not v:FindFirstChild("Contents")
            and not (v:FindFirstChild("Door") and v.Door:FindFirstChild("Lock")) then
                local handle = v.Door and v.Door:FindFirstChild("Handle")
                if handle and not isUnsafe(handle.Position) then
                    local d = (hrp.Position-handle.Position).Magnitude
                    if d<dist then dist,best=d,v end
                end
            end
        end
        return best
    end

    local storage = getNearest()
    if not storage then hrp.CFrame=startCF return end
    lastStorage = storage

    local handle = storage.Door.Handle
    hrp.CFrame = handle.CFrame * CFrame.new(0,2.5,-1.5)
    task.wait()

    cam.CFrame = CFrame.new(cam.CFrame.Position, handle.Position)
    task.wait(0.1)

    for i = 1, 10 do
    for _,pp in ipairs(handle:GetDescendants()) do
        if pp:IsA("ProximityPrompt") then
            pp.HoldDuration = 0
            fireproximityprompt(pp)
        end
    end
    task.wait()
end

    local contents
    local t=os.clock()
    while os.clock()-t<1 do
        contents = storage:FindFirstChild("Contents")
        if contents then break end
        task.wait()
    end
    if not contents then hrp.CFrame=startCF return end

    local loot = contents:FindFirstChild("Loot")
    if not loot then hrp.CFrame=startCF return end

    while #loot:GetChildren()>0 do
        for _,item in ipairs(loot:GetChildren()) do
            local pos
            if item:IsA("BasePart") then pos=item.Position
            elseif item:IsA("Model") then
                local p=item:FindFirstChildWhichIsA("BasePart")
                if p then pos=p.Position end
            elseif item:IsA("Attachment") then pos=item.WorldPosition end

            if pos then
                hrp.CFrame = CFrame.new(pos + Vector3.new(0,2.5,0))
                task.wait()
                cam.CFrame = CFrame.new(cam.CFrame.Position) * LOOK_DOWN
                task.wait(0.1)
                for _,pp in ipairs(item:GetDescendants()) do
                    if pp:IsA("ProximityPrompt") then
                        pp.HoldDuration=0
                        fireproximityprompt(pp)
                    end
                end
            end
        end
        task.wait()
    end

    hrp.CFrame = startCF
end

