task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestDist = math.huge
        local priorityTarget = nil

        local function isVisible(part)
            local ray = Ray.new(camPos, (part.Position - camPos).Unit * (part.Position - camPos).Magnitude)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
            return hit and hit:IsDescendantOf(part.Parent)
        end

        local function getAimPart(entity)
            local part = entity:FindFirstChild("Head")
            if not part then part = entity:FindFirstChild("HumanoidRootPart") end
            if not part then part = entity:FindFirstChildWhichIsA("BasePart") end
            return part
        end

        local function evaluateTarget(aimPart, isPlayer)
            if not aimPart then return nil, nil end
            local screenPos, onScreen = cam:WorldToViewportPoint(aimPart.Position)
            if not onScreen then return nil, nil end
            local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
            local dx = screenPos.X - fPos.X
            local dy = screenPos.Y - fPos.Y
            local screenDist = math.sqrt(dx*dx + dy*dy)
            if screenDist <= fovSize/2 and isVisible(aimPart) then
                return aimPart, screenDist
            end
            return nil, nil
        end

        if targetPlayers and targetPlayer and targetPlayer.Character then
            local character = targetPlayer.Character
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 and not table.find(WhitelistPlayers, targetPlayer.Name) then
                local hasShield = character:FindFirstChild("PvPShield") ~= nil
                if not hasShield then
                    local aimPart = getAimPart(character)
                    if aimPart then
                        local _, dist = evaluateTarget(aimPart, true)
                        if dist then
                            priorityTarget = aimPart
                            bestDist = dist
                        end
                    end
                end
            end
        end

        if priorityTarget then
            cam.CFrame = CFrame.lookAt(camPos, priorityTarget.Position)
            continue
        end

        if targetPlayers then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr == LocalPlayer then continue end
                if table.find(WhitelistPlayers, plr.Name) then continue end
                local character = plr.Character
                if not character then continue end
                local humanoid = character:FindFirstChild("Humanoid")
                if not humanoid or humanoid.Health <= 0 then continue end
                local hasShield = character:FindFirstChild("PvPShield") ~= nil
                if hasShield then continue end

                local aimPart = getAimPart(character)
                if aimPart then
                    local part, dist = evaluateTarget(aimPart, true)
                    if part and dist < bestDist then
                        bestTarget = part
                        bestDist = dist
                    end
                end
            end
        end

        if targetMobs and workspace:FindFirstChild("Mobs") then
            for _, mob in ipairs(workspace.Mobs:GetChildren()) do
                if mob:IsA("Model") then
                    local humanoid = mob:FindFirstChild("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        local aimPart = getAimPart(mob)
                        if aimPart then
                            local part, dist = evaluateTarget(aimPart, false)
                            if part and dist < bestDist then
                                bestTarget = part
                                bestDist = dist
                            end
                        end
                    end
                end
            end
        end

        if bestTarget then
            cam.CFrame = CFrame.lookAt(camPos, bestTarget.Position)
        end
    end
end)

