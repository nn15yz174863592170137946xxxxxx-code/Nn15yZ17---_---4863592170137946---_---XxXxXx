    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("RemoteEvent")
    for itemName, _ in pairs(itemNames) do
        remote:FireServer("SellItem", itemName, npc)
        task.wait(0.05)
    end

    if startPos and hrp then
        hrp.CFrame = startPos
    end
end

