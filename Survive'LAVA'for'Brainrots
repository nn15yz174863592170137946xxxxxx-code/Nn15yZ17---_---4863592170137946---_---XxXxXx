local function getRarityPosition(rarityFolder)
	if not rarityFolder then return nil end
	local ok, pivot = pcall(function() return rarityFolder:GetPivot() end)
	if ok and pivot then return pivot.Position end
	if rarityFolder.PrimaryPart and rarityFolder.PrimaryPart:IsA("BasePart") then
		return rarityFolder.PrimaryPart.Position
	end
	local p = rarityFolder:FindFirstChildWhichIsA("BasePart", true)
	if p then return p.Position end
	return nil
end

local function orderRaritiesByDistance()
	local names = {}
	for _, child in ipairs(raritiesRoot:GetChildren()) do
		table.insert(names, child.Name)
	end
	table.sort(names, function(a, b)
		local fa = raritiesRoot:FindFirstChild(a)
		local fb = raritiesRoot:FindFirstChild(b)
		local pa = getRarityPosition(fa)
		local pb = getRarityPosition(fb)
		local char = LocalPlayer.Character
		local hrp = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"))
		if not hrp then return a < b end -- fallback alphabetical if no hrp
		if pa and pb then
			return (pa - hrp.Position).Magnitude < (pb - hrp.Position).Magnitude
		elseif pa then
			return true
		elseif pb then
			return false
		end
		return a < b
	end)
	return names
end

local rarityNames = orderRaritiesByDistance()

