local notifyToggles = {}
local lastBestValues = {}

for _, rarity in ipairs(rarityNames) do
	local rname = rarity
	BrainrotsGroup:AddButton(rname, function()
		local entry, val, raw = findBestBrainrotForRarity(rname)
		if not entry then
			Library:Notify(val, 4) -- val contains error string
			return
		end
		local cf = getCFrameForEntry(entry)
		if not cf then
			Library:Notify("Couldn't find teleport position for "..rname, 4)
			return
		end
		if tpToCFrameOnce(cf) then
			local human = raw or (val and tostring(val) or "unknown")
			Library:Notify(("Teleported to best %s brainrot (%s)"):format(rname, human), 3)
		else
			Library:Notify("Teleport failed (no character)", 3)
		end
	end)

	notifyToggles[rname] = false
	NotifyGroup:AddToggle("Notify_"..rname, {
		Text = rname,
		Default = false,
		Callback = function(v)
			notifyToggles[rname] = v
		end
	})
	local _, v = findBestBrainrotForRarity(rname)
	if type(v) == "number" then
		lastBestValues[rname] = v
	else
		lastBestValues[rname] = nil
	end
end

task.spawn(function()
	while true do
		for _, rname in ipairs(rarityNames) do
			local entry, val, raw = findBestBrainrotForRarity(rname)
			local numericVal = nil
			if entry and type(val) == "number" then numericVal = val end
			local prev = lastBestValues[rname
			if numericVal then
				local changed = false
				if not prev then changed = true end
				if prev and numericVal ~= prev then changed = true end
				lastBestValues[rname] = numericVal
				if changed and notifyToggles[rname] then
					local human = raw
					if not human then
						local n = numericVal
						if n >= 1000000 then
							human = string.format("$%.2fm/s", n / 1000000)
						elseif n >= 1000 then
							human = string.format("$%.1fk/s", n / 1000)
						else
							human = string.format("$%d/s", math.floor(n))
						end
					end
					Library:Notify(("Rarity: %s (%s) Spawned!"):format(rname, human), 3)
				end
			else
				lastBestValues[rname] = nil
			end
		end
		task.wait(1)
	end
end)

