-- ===== helpers: locate folders ===== --
local function findGameFolderChild(...)
	local node = workspaceRef:FindFirstChild("GameFolder")
	if not node then return nil end
	for i = 1, select("#", ...) do
		local name = select(i, ...)
		if not node then return nil end
		node = node:FindFirstChild(name)
	end
	return node
end

local raritiesRoot = findGameFolderChild("Rarities")
local brainrotsRoot = findGameFolderChild("Brainrots")

-- ===== parse cash string ===== --
local function parseCashText(txt)
	if not txt then return nil end
	local s = tostring(txt):lower()
	local num, unit = s:match("([%d%,%.]+)%s*([km]?)")
	if not num then
		num = s:match("%$?%s*([%d%,%.]+)")
		unit = s:match("([km])")
	end
	if not num then return nil end
	num = num:gsub(",", "")
	local n = tonumber(num)
	if not n then return nil end
	if unit == "k" then n = n * 1000 end
	if unit == "m" then n = n * 1000000 end
	return n
end

local function extractCashFromEntry(entry)
	local root = entry:FindFirstChild("RootPart")
	if not root then return nil, nil end

	local att = root:FindFirstChild("BrainrotAtt")
	if not att then return nil, nil end

	local gui = att:FindFirstChild("BillboardGui")
	if not gui then return nil, nil end

	local cash = gui:FindFirstChild("Cash")
	if not cash or not cash:IsA("TextLabel") then return nil, nil end

	local txt = cash.Text
	if not txt then return nil, nil end

	local val = parseCashText(txt)
	if not val then return nil, nil end

	return val, txt
end

local function getCFrameForEntry(entry)
	if not entry then return nil end
	if entry:IsA("BasePart") then return entry.CFrame end
	if entry:IsA("Model") then
		local ok, pivot = pcall(function() return entry:GetPivot() end)
		if ok and pivot then return pivot end
		if entry.PrimaryPart and entry.PrimaryPart:IsA("BasePart") then
			return entry.PrimaryPart.CFrame
		end
		local bp = entry:FindFirstChildWhichIsA("BasePart", true)
		if bp then return bp.CFrame end
	end
	local any = entry:FindFirstChildWhichIsA("BasePart", true)
	if any then return any.CFrame end
	return nil
end

local function findBestBrainrotForRarity(rarityName)
	if not brainrotsRoot then return nil, "Missing workspace.GameFolder.Brainrots" end
	local rarFolder = brainrotsRoot:FindFirstChild(rarityName)
	if not rarFolder then return nil, ("No brainrots folder for rarity '%s'"):format(rarityName) end

	local bestEntry, bestValue, bestText = nil, nil, nil
	for _, child in ipairs(rarFolder:GetChildren()) do
		local val, raw = extractCashFromEntry(child)
		if val then
			if not bestValue or val > bestValue then
				bestValue = val
				bestEntry = child
				bestText = raw
			end
		end
	end

	if not bestEntry then
		return nil, ("No brainrot found in '%s'"):format(rarityName)
	end
	return bestEntry, bestValue, bestText
end

local function tpToCFrameOnce(cf)
	if not cf then return false end
	local char = LocalPlayer.Character
	if not char then return false end
	local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
	if not hrp then return false end
	hrp.CFrame = cf * CFrame.new(0, 3, 0)
	return true
end

