-- ===== STATE ===== --
local AutoShoot = false
local KillAll = false
local NoCooldown = false

-- ===== COOLDOWN STATE ===== --
local lastShot = 0

local function getCooldown()
local char = LP.Character
if char then
for _, tool in ipairs(char:GetChildren()) do
if tool:IsA("Tool") then
local cd = tool:GetAttribute("Cooldown")
if typeof(cd) == "number" then
return cd
end
end
end
end

for _, tool in ipairs(LP.Backpack:GetChildren()) do  
	if tool:IsA("Tool") then  
		local cd = tool:GetAttribute("Cooldown")  
		if typeof(cd) == "number" then  
			return cd  
		end  
	end  
end  

return 0

end

local function canFire()
if KillAll or NoCooldown then
return true
end
local cd = getCooldown()
if cd <= 0 then
return true
end
return (os.clock() - lastShot) >= cd
end

local function markShot()
lastShot = os.clock()
end

-- ===== WALL CHECK ===== --
local function hasLineOfSight(origin, targetPos, ignore)
local p = RaycastParams.new()
p.FilterType = Enum.RaycastFilterType.Exclude
p.FilterDescendantsInstances = ignore
p.IgnoreWater = true
return not workspace:Raycast(origin, targetPos - origin, p)
end

-- ===== AUTO EQUIP (KILL ALL) ===== --
local function equipAllTools()
local char = LP.Character
if not char then return end
for _, tool in ipairs(LP.Backpack:GetChildren()) do
if tool:IsA("Tool") then
tool.Parent = char
end
end
end

