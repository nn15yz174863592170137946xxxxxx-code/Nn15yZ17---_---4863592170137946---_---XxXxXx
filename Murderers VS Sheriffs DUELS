local function createESP(plr)
if plr == LP then return end

local gui = Instance.new("BillboardGui")  
gui.Size = UDim2.fromOffset(360,50)  
gui.AlwaysOnTop = true  
  gui.Enabled = false  
  gui.Adornee = nil

gui.StudsOffset = Vector3.new(0, 4.5, 0)

local txt = Instance.new("TextLabel")  
txt.Size = UDim2.fromScale(1,1)  
txt.BackgroundTransparency = 1  
txt.TextColor3 = Color3.new(255,255,255)  
txt.TextStrokeColor3 = Color3.new(0,0,0)  
txt.TextStrokeTransparency = 0  
txt.Font = Enum.Font.SourceSans  
txt.TextWrapped = false  
  txt.TextTruncate = Enum.TextTruncate.AtEnd  
  txt.RichText = true

txt.FontFace = Font.new(
"rbxasset://fonts/families/SourceSansPro.json",
Enum.FontWeight.Regular,
Enum.FontStyle.Normal
)
txt.TextSize = 20
txt.Parent = gui

ESPObjects[plr] = {Gui=gui, Text=txt}

end

local function removeESP(plr)
if ESPObjects[plr] then
ESPObjects[plr].Gui:Destroy()
ESPObjects[plr] = nil
end
end

for _,p in ipairs(Players:GetPlayers()) do
createESP(p)
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

RunService.RenderStepped:Connect(function()
if not ESPEnabled then
for _,v in pairs(ESPObjects) do
v.Gui.Enabled = false
end
return
end

for plr,data in pairs(ESPObjects) do  
	local char = plr.Character  
	local hrp = char and char:FindFirstChild("HumanoidRootPart")  
	local hum = char and char:FindFirstChildOfClass("Humanoid")  
	if not hrp or not hum then  
		data.Gui.Enabled = false  
		continue  
	end  

	data.Gui.Adornee = hrp  
         data.Gui.Parent = hrp  
	data.Gui.Enabled = true  

	local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)  
	data.Text.Text =
	"<b>Name: " .. plr.Name ..
	" | Health: " .. math.floor(hum.Health) ..
	" | Studs: " .. dist .. "</b>"
end

end)

-- ===== ALL PART TARGET ===== --
local HITBOX_ORDER = {
"Head",
"HumanoidRootPart",
"UpperTorso","LowerTorso","Torso",
"LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm",
"LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg"
}

local function getVisiblePart(origin, model, ignore)
for _, name in ipairs(HITBOX_ORDER) do
local part = model:FindFirstChild(name, true)
if part and part:IsA("BasePart") and part.Transparency < 1 then
if hasLineOfSight(origin, part.Position, ignore) then
return part
end
end
end
end

-- ===== CORE LOOP ===== --
task.spawn(function()
while task.wait(0.15) do
if not (AutoShoot or KillAll) then continue end

if KillAll then  
		equipAllTools()  
	end  

	if AutoShoot and not canFire() then continue end  

	local char = LP.Character  
	local hrp = char and char:FindFirstChild("HumanoidRootPart")  
	if not hrp then continue end  

	local origin = hrp.Position  
	local fired = false  

	for _, model in ipairs(workspace:GetChildren()) do  
		if not model:IsA("Model") then continue end  
		local hum = model:FindFirstChildOfClass("Humanoid")  
		if not hum or hum.Health <= 0 then continue end

local targetPart = getVisiblePart(origin, model, {char, model})
if not targetPart then continue end

local plr = Players:GetPlayerFromCharacter(model)  
		if plr and plr.Team == LP.Team then continue end  

		Remote:FireServer(origin, targetPart.Position, targetPart, targetPart.Position)  
		fired = true  
	end  

	if fired then  
		markShot()  
	end  
end

end)

