local function createESPBillboard(color, textSize)
    textSize = textSize or 20
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.fromOffset(400, 60)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.StudsOffset = Vector3.new(0, 3, 0)
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.ClipsDescendants = false

    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.fromScale(1, 1)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextStrokeColor3 = Color3.new(0,0,0)
    txt.TextStrokeTransparency = 0.3
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = textSize
    txt.TextWrapped = true
    txt.TextTruncate = Enum.TextTruncate.None
    txt.RichText = true
    return gui, txt
end

local function getAdorneePart(obj)
    if obj:IsA("BasePart") then
        return obj
    elseif obj:IsA("Model") then
        return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    end
    return nil
end

task.spawn(function()
    while task.wait(0.1) do
        local camPos = cam.CFrame.Position

        local npcsFolder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("NPCs")
        if not npcsFolder then
            for _, data in pairs(BossESPObjects) do if data.Gui then data.Gui:Destroy() end end
            for _, data in pairs(ZombieESPObjects) do if data.Gui then data.Gui:Destroy() end end
            for _, data in pairs(FriendlyESPObjects) do if data.Gui then data.Gui:Destroy() end end
            BossESPObjects = {}
            ZombieESPObjects = {}
            FriendlyESPObjects = {}
        else
            local currentNpcs = {}
            local npcType = {}

            for _, folder in ipairs(npcsFolder:GetChildren()) do
                if folder:IsA("Folder") then
                    local name = folder.Name:lower()
                    if name == "bosses" then
                        for _, model in ipairs(folder:GetChildren()) do
                            if model:IsA("Model") then currentNpcs[model] = "Boss" end
                        end
                    elseif name == "enemies" then
                        for _, model in ipairs(folder:GetChildren()) do
                            if model:IsA("Model") then currentNpcs[model] = "Zombie" end
                        end
                    elseif name == "friendlies" then
                        for _, model in ipairs(folder:GetChildren()) do
                            if model:IsA("Model") then currentNpcs[model] = "Friendly" end
                        end
                    end
                end
            end

            for model, data in pairs(BossESPObjects) do
                if not currentNpcs[model] then if data.Gui then data.Gui:Destroy() end BossESPObjects[model] = nil end
            end
            for model, data in pairs(ZombieESPObjects) do
                if not currentNpcs[model] then if data.Gui then data.Gui:Destroy() end ZombieESPObjects[model] = nil end
            end
            for model, data in pairs(FriendlyESPObjects) do
                if not currentNpcs[model] then if data.Gui then data.Gui:Destroy() end FriendlyESPObjects[model] = nil end
            end

            for model, npcTypeStr in pairs(currentNpcs) do
                local humanoid = model:FindFirstChildOfClass("Humanoid")
                if not humanoid or humanoid.Health <= 0 then continue end
                local head = model:FindFirstChild("Head")
                if not head then continue end

                local dist = (camPos - head.Position).Magnitude
                local displayName = model.Name
                local offset = 1 + (dist * 0.075)

                if npcTypeStr == "Boss" and bossesESP then
                    if not BossESPObjects[model] then BossESPObjects[model] = {Gui = nil, Text = nil} end
                    local data = BossESPObjects[model]
                    if not data.Gui then data.Gui, data.Text = createESPBillboard(Color3.new(1, 0, 0), 18); data.Gui.Name = "BossESP"; data.Gui.Parent = game:GetService("CoreGui") end
                    data.Gui.StudsOffset = Vector3.new(0, offset, 0); data.Gui.Adornee = head; data.Gui.Enabled = true
                    data.Text.Text = string.format("<b>Name: %s | Studs: %d</b>", displayName, math.floor(dist))
                elseif npcTypeStr == "Zombie" and zombiesESP then
                    if not ZombieESPObjects[model] then ZombieESPObjects[model] = {Gui = nil, Text = nil} end
                    local data = ZombieESPObjects[model]
                    if not data.Gui then data.Gui, data.Text = createESPBillboard(Color3.new(0, 1, 0), 18); data.Gui.Name = "ZombieESP"; data.Gui.Parent = game:GetService("CoreGui") end
                    data.Gui.StudsOffset = Vector3.new(0, offset, 0); data.Gui.Adornee = head; data.Gui.Enabled = true
                    data.Text.Text = string.format("<b>Name: %s | Studs: %d</b>", displayName, math.floor(dist))
                elseif npcTypeStr == "Friendly" and friendliesESP then
                    if not FriendlyESPObjects[model] then FriendlyESPObjects[model] = {Gui = nil, Text = nil} end
                    local data = FriendlyESPObjects[model]
                    if not data.Gui then data.Gui, data.Text = createESPBillboard(Color3.new(1, 1, 1), 18); data.Gui.Name = "FriendlyESP"; data.Gui.Parent = game:GetService("CoreGui") end
                    data.Gui.StudsOffset = Vector3.new(0, offset, 0); data.Gui.Adornee = head; data.Gui.Enabled = true
                    data.Text.Text = string.format("<b>Name: %s | Studs: %d</b>", displayName, math.floor(dist))
                end
            end
        end

        local gameObjectsFolder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("GameObjects")
        if not gameObjectsFolder then
            for _, data in pairs(ContainerESPObjects) do if data.Gui then data.Gui:Destroy() end end
            for _, data in pairs(PickupESPObjects) do if data.Gui then data.Gui:Destroy() end end
            ContainerESPObjects = {}
            PickupESPObjects = {}
        else
            local currentObjects = {}
            for _, child in ipairs(gameObjectsFolder:GetChildren()) do
                currentObjects[child] = true
            end

            for obj, data in pairs(ContainerESPObjects) do
                if not currentObjects[obj] then
                    if data.Gui then data.Gui:Destroy() end
                    ContainerESPObjects[obj] = nil
                end
            end
            for obj, data in pairs(PickupESPObjects) do
                if not currentObjects[obj] then
                    if data.Gui then data.Gui:Destroy() end
                    PickupESPObjects[obj] = nil
                end
            end

            for _, child in ipairs(gameObjectsFolder:GetChildren()) do
                local part = getAdorneePart(child)
                if not part then continue end

                local name = child.Name:lower()
                local displayName = ""
                local isContainer = false
                local isPickup = false

                if string.find(name, "^container_ammunition") then
                    if not ammoContainerESP then continue end
                    isContainer = true
                    displayName = child.Name:gsub("^container_", "")
                elseif string.find(name, "^container_medical") then
                    if not medicalContainerESP then continue end
                    isContainer = true
                    displayName = child.Name:gsub("^container_", "")
                elseif name == "container_cash_register" then
                    if not cashContainerESP then continue end
                    isContainer = true
                    displayName = child.Name:gsub("^container_", "")
                end

                if not isContainer then
                    if string.find(name, "^pickup_ammo") then
                        if not ammoPickupESP then continue end
                        isPickup = true
                        displayName = child.Name:gsub("^pickup_", "")
                    elseif string.find(name, "^pickup_armor") then
                        if not armorPickupESP then continue end
                        isPickup = true
                        displayName = child.Name:gsub("^pickup_", "")
                    elseif string.find(name, "^pickup_money") then
                        if not moneyPickupESP then continue end
                        isPickup = true
                        displayName = child.Name:gsub("^pickup_", "")
                    elseif string.find(name, "^pickup_medkit") then
                        if not medkitPickupESP then continue end
                        isPickup = true
                        displayName = child.Name:gsub("^pickup_", "")
                    elseif string.find(name, "^weapon_pickup") or string.find(name, "^attachment_pickup") then
                        if not weaponPickupESP then continue end
                        isPickup = true
                        displayName = child.Name:gsub("^(weapon_|attachment_)", "")
                    end
                end

                if isContainer then
                    if not ContainerESPObjects[child] then
                        ContainerESPObjects[child] = {Gui = nil, Text = nil}
                    end
                    local data = ContainerESPObjects[child]
                    if not data.Gui then
                        data.Gui, data.Text = createESPBillboard(Color3.new(0, 1, 1), 15)
                        data.Gui.Name = "ContainerESP"
                        data.Gui.Parent = game:GetService("CoreGui")
                    end
                    data.Gui.StudsOffset = Vector3.new(0, 0, 0)
                    data.Gui.Adornee = part
                    data.Gui.Enabled = true
                    data.Text.Text = string.format("<b>%s</b>", displayName)
                elseif isPickup then
                    if not PickupESPObjects[child] then
                        PickupESPObjects[child] = {Gui = nil, Text = nil}
                    end
                    local data = PickupESPObjects[child]
                    if not data.Gui then
                        data.Gui, data.Text = createESPBillboard(Color3.new(0, 1, 1), 15)
                        data.Gui.Name = "PickupESP"
                        data.Gui.Parent = game:GetService("CoreGui")
                    end
                    data.Gui.StudsOffset = Vector3.new(0, 0, 0)
                    data.Gui.Adornee = part
                    data.Gui.Enabled = true
                    data.Text.Text = string.format("<b>%s</b>", displayName)
                end
            end

            if not ammoContainerESP or not medicalContainerESP or not cashContainerESP then
                for obj, data in pairs(ContainerESPObjects) do
                    local n = obj.Name:lower()
                    if (n:find("^container_ammunition") and not ammoContainerESP) or
                       (n:find("^container_medical") and not medicalContainerESP) or
                       (n == "container_cash_register" and not cashContainerESP) then
                        if data.Gui then data.Gui.Enabled = false end
                    end
                end
            end
            if not ammoPickupESP or not armorPickupESP or not moneyPickupESP or not medkitPickupESP or not weaponPickupESP then
                for obj, data in pairs(PickupESPObjects) do
                    local n = obj.Name:lower()
                    if (n:find("^pickup_ammo") and not ammoPickupESP) or
                       (n:find("^pickup_armor") and not armorPickupESP) or
                       (n:find("^pickup_money") and not moneyPickupESP) or
                       (n:find("^pickup_medkit") and not medkitPickupESP) or
                       ((n:find("^weapon_pickup") or n:find("^attachment_pickup")) and not weaponPickupESP) then
                        if data.Gui then data.Gui.Enabled = false end
                    end
                end
            end
        end
    end
end)

