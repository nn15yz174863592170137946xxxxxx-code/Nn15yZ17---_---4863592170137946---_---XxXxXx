local function updateBtn()
    if aimEnabled then
        btn.Text="Aimlock : ON"
        btn.BackgroundColor3=Color3.fromRGB(255,128,0)
        crossH.Visible=true
        crossV.Visible=true
        fovCircle.Visible=true
    else
        btn.Text="Aimlock : OFF"
        btn.BackgroundColor3=Color3.new(0,0,0)
        crossH.Visible=false
        crossV.Visible=false
        fovCircle.Visible=false
    end
end

local function toggleAim(v)
    aimEnabled=v
    Toggles.EnableAimlock:SetValue(v)
    updateBtn()
end

btn.MouseButton1Click:Connect(function() toggleAim(not aimEnabled) end)
game:GetService("UserInputService").InputBegan:Connect(function(i,g)
    if g then return end
    if i.KeyCode.Name == aimKey then toggleAim(not aimEnabled) end
end)
Toggles.EnableAimlock:OnChanged(function(v) task.spawn(function() toggleAim(v) end) end)
