-- ===== aimlock loop ===== --
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestDist = math.huge

        local npcsFolder = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("NPCs")
        if not npcsFolder then continue end

        local npcs = {}
        for _, folder in ipairs(npcsFolder:GetChildren()) do
            if folder:IsA("Folder") then
                local name = folder.Name:lower()
                if name == "enemies" or name == "bosses" then
                    for _, model in ipairs(folder:GetChildren()) do
                        if model:IsA("Model") then
                            table.insert(npcs, model)
                        end
                    end
                end
            end
        end

        for _, npc in ipairs(npcs) do
            local humanoid = npc:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end

            local head = npc:FindFirstChild("Head")
            if not head then continue end

            local ray = Ray.new(camPos, (head.Position - camPos).Unit * (head.Position - camPos).Magnitude)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
            if hit and hit:IsDescendantOf(npc) then
                if lockAnywhere then
                    local dist = (head.Position - camPos).Magnitude
                    if dist < bestDist then
                        bestTarget = head
                        bestDist = dist
                    end
                else
                    local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                        local dx = screenPos.X - fPos.X
                        local dy = screenPos.Y - fPos.Y
                        local screenDist = math.sqrt(dx*dx + dy*dy)
                        if screenDist <= fovSize/2 and screenDist < bestDist then
                            bestTarget = head
                            bestDist = screenDist
                        end
                    end
                end
            end
        end

        if bestTarget then
            cam.CFrame = CFrame.lookAt(camPos, bestTarget.Position)
        end
    end
end)

