-- ===== MINESWEEPER LOGIC ===== --
local PartsFolder = workspace:WaitForChild("Flag"):WaitForChild("Parts")
local OFFSETS = {
    Vector3.new( 1,0, 0), Vector3.new(-1,0, 0),
    Vector3.new( 0,0, 1), Vector3.new( 0,0,-1),
    Vector3.new( 1,0, 1), Vector3.new(-1,0, 1),
    Vector3.new( 1,0,-1), Vector3.new(-1,0,-1),
}

-- ===== OPTIMIZATION CACHE ===== --
local neighborCache = {}
local solved = {}

local function getNeighbors(part, parts)
    if neighborCache[part] then return neighborCache[part] end
    local size = part.Size.X
    local list = {}
    for _,off in ipairs(OFFSETS) do
        local pos = part.Position + off * size
        for _,p in ipairs(parts) do
            if (p.Position - pos).Magnitude < 0.1 then
                table.insert(list, p)
                break
            end
        end
    end
    neighborCache[part] = list
    return list
end

local function hasModel(part)
    for _,c in ipairs(part:GetChildren()) do
        if c:IsA("Model") then return true end
    end
    return false
end

-- ===== LOOP ===== --
task.spawn(function()
    while task.wait(flagDelay) do
        local parts = PartsFolder:GetChildren()

        -- ===== CALCULATOR ===== --
        if calcEnabled then
            local changed = true
            while changed do
                changed = false
                for _,clear in ipairs(parts) do
                    local gui = clear:FindFirstChild("NumberGui")
                    local label = gui and gui:FindFirstChild("TextLabel")
                    local number = label and tonumber(label.Text)
                    if not number then continue end

                    local neighbors = getNeighbors(clear, parts)
                    local hidden, flagged = {}, 0

                    for _,n in ipairs(neighbors) do
                        local c = n.BrickColor.Name
                        if c == "Really red" then
                            flagged += 1
                        elseif c ~= "Ghost grey" and c ~= "Quill grey" then
                            table.insert(hidden, n)
                        end
                    end

                    if flagged == number and #hidden > 0 then
                        for _,h in ipairs(hidden) do
                            if h.BrickColor.Name ~= "Toothpaste" then
                                h.BrickColor = BrickColor.new("Toothpaste")
                                changed = true
                            end
                        end
                        solved[clear] = true

                    elseif flagged + #hidden == number and #hidden > 0 then
                        for _,h in ipairs(hidden) do
                            if h.BrickColor.Name ~= "Really red" then
                                h.BrickColor = BrickColor.new("Really red")
                                changed = true
                            end
                        end
                        solved[clear] = true
                    end
                end
            end
        end

        -- ===== AUTO FLAG ===== --
        if autoFlag and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local closest, dist
            for _,p in ipairs(parts) do
                if p.BrickColor.Name ~= "Really red" or hasModel(p) then continue end
                local d = (p.Position - hrp.Position).Magnitude
                if d <= flagDistance and (not dist or d < dist) then
                    local cd = p:FindFirstChild("ClickDetector")
                    if cd then closest, dist = cd, d end
                end
            end
            if closest then fireclickdetector(closest) end
        end
    end
end)

