local survivorsESP = false

ESPGroup:AddToggle("BotsESP", {Text="Bots ESP", Default=false, Callback=function(v) botsESP=v end})
ESPGroup:AddToggle("InfectionsESP", {Text="Infections ESP", Default=false, Callback=function(v) infectionsESP=v end})
ESPGroup:AddToggle("KillerESP", {Text="Killer ESP", Default=false, Callback=function(v) killerESP=v end})
ESPGroup:AddToggle("SurvivorsESP", {Text="Survivors ESP", Default=false, Callback=function(v) survivorsESP=v end})

local espObjects = {}

local function createESPBillboard(color, textSize, offset)
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.fromOffset(300, 50)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.StudsOffset = offset
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.ClipsDescendants = false

    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.fromScale(1, 1)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextStrokeColor3 = Color3.new(0,0,0)
    txt.TextStrokeTransparency = 0.3
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = textSize
    txt.TextWrapped = true
    txt.RichText = true
    return gui, txt
end

local function getTeamColor(team)
    if team == "Bots" then
        return Color3.fromRGB(192,192,192)
    elseif team == "Infections" then
        return Color3.fromRGB(0,255,0)
    elseif team == "Killer" then
        return Color3.fromRGB(255,0,0)
    elseif team == "Survivors" then
        return Color3.fromRGB(255,255,255)
    else
        return Color3.new(0.5,0.5,0.5)
    end
end

local function getTextSize(team)
    if team == "Bots" then
        return 15
    else
        return 20
    end
end

local function getOffset(team)
    if team == "Bots" then
        return Vector3.new(0,0,0)
    else
        return Vector3.new(0,2.5,0)
    end
end

task.spawn(function()
    while task.wait(0.03) do
        local localChar = LocalPlayer.Character
        local hrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
        local hrpPos = hrp and hrp.Position or cam.CFrame.Position

        local function getTeam(model)
            local parent = model.Parent
            if parent and parent.Parent == workspace:FindFirstChild("Characters") then
                return parent.Name
            end
            return nil
        end

        for model, data in pairs(espObjects) do
            if not model.Parent then
                if data.billboard then data.billboard:Destroy() end
                espObjects[model] = nil
            end
        end

        local charactersFolder = workspace:FindFirstChild("Characters")
        if not charactersFolder then continue end

        for _, teamFolder in ipairs(charactersFolder:GetChildren()) do
            if teamFolder:IsA("Folder") or teamFolder:IsA("Model") then
                local teamName = teamFolder.Name
                if teamName == "Bots" or teamName == "Infections" or teamName == "Killer" or teamName == "Survivors" then
                    local teamEnabled = false
                    if teamName == "Bots" and botsESP then teamEnabled = true
                    elseif teamName == "Infections" and infectionsESP then teamEnabled = true
                    elseif teamName == "Killer" and killerESP then teamEnabled = true
                    elseif teamName == "Survivors" and survivorsESP then teamEnabled = true
                    end

                    if not teamEnabled then
                        for _, model in ipairs(teamFolder:GetChildren()) do
                            if espObjects[model] then
                                espObjects[model].billboard.Enabled = false
                            end
                        end
                    else
                        for _, model in ipairs(teamFolder:GetChildren()) do
                            if model == localChar then continue end
                            if not model:IsA("Model") then continue end

                            local hum = model:FindFirstChildOfClass("Humanoid")
                            if not hum or hum.Health <= 0 then
                                if espObjects[model] then
                                    espObjects[model].billboard.Enabled = false
                                end
                                continue
                            end

                            local head = model:FindFirstChild("Head")
                            local adornee = head or model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildWhichIsA("BasePart")
                            if not adornee then continue end

                            if not espObjects[model] then
                                local color = getTeamColor(teamName)
                                local textSize = getTextSize(teamName)
                                local offset = getOffset(teamName)
                                local gui, txt = createESPBillboard(color, textSize, offset)
                                gui.Name = model.Name .. "_ESP"
                                gui.Parent = game:GetService("CoreGui")
                                espObjects[model] = {billboard = gui, text = txt}
                            end

                            local data = espObjects[model]
                            data.billboard.Adornee = adornee
                            data.billboard.Enabled = true
                            local dist = (hrpPos - adornee.Position).Magnitude
                            local health = math.floor(hum.Health)
                            data.text.Text = string.format("<b>%s | Health: %d | %d studs</b>", model.Name, health, math.floor(dist))
                        end
                    end
                end
            end
        end
    end
end)

