-- ===== aimlock loop ===== --
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local localTeam = nil
        local parent = char.Parent
        if parent and parent.Parent == workspace:FindFirstChild("Characters") then
            localTeam = parent.Name
        end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestDist = math.huge

        local function getHead(model)
            return model:FindFirstChild("Head")
        end

        local function isAlive(model)
            local hum = model:FindFirstChildOfClass("Humanoid")
            return hum and hum.Health > 0
        end

        local function isVisible(part, targetModel)
            local ray = Ray.new(camPos, (part.Position - camPos).Unit * (part.Position - camPos).Magnitude)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
            return hit and hit:IsDescendantOf(targetModel)
        end

        local candidates = {}

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if table.find(WhitelistPlayers, plr.Name) then continue end

            local character = plr.Character
            if not character then continue end

            local head = getHead(character)
            if not head then continue end

            if head.Transparency == 1 then continue end

            local hum = character:FindFirstChildOfClass("Humanoid")
            if hum then
                if hum.WalkSpeed > 50 then continue end
                if hum.WalkSpeed < 5 then continue end
            end

            local targetTeam = nil
            local targetParent = character.Parent
            if targetParent and targetParent.Parent == workspace:FindFirstChild("Characters") then
                targetTeam = targetParent.Name
            end

            if targetTeam == "Lobby" then continue end

            if localTeam == "Infections" or localTeam == "Killer" then
                if targetTeam ~= "Survivors" then continue end
            elseif localTeam == "Survivors" then
                if targetTeam == "Survivors" then continue end
            end

            if not isAlive(character) then continue end

            table.insert(candidates, {
                head = head,
                model = character,
                team = targetTeam,
            })
        end

        local infectionCandidates = {}
        local nonInfectionCandidates = {}
        for _, c in ipairs(candidates) do
            local dist = (c.head.Position - camPos).Magnitude
            if c.team == "Infections" and dist <= 200 then
                table.insert(infectionCandidates, c)
            else
                table.insert(nonInfectionCandidates, c)
            end
        end

        local finalCandidates = (#infectionCandidates > 0) and infectionCandidates or (#nonInfectionCandidates > 0 and nonInfectionCandidates or {})

        for _, c in ipairs(finalCandidates) do
            local head = c.head
            local model = c.model

            if not isVisible(head, model) then continue end

            if lockAnywhere then
                local dist = (head.Position - camPos).Magnitude
                if dist < bestDist then
                    bestTarget = head
                    bestDist = dist
                end
            else
                local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                if onScreen then
                    local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                    local dx = screenPos.X - fPos.X
                    local dy = screenPos.Y - fPos.Y
                    local screenDist = math.sqrt(dx*dx + dy*dy)
                    if screenDist <= fovSize/2 and screenDist < bestDist then
                        bestTarget = head
                        bestDist = screenDist
                    end
                end
            end
        end

        if localTeam == "Survivors" then
            local botsFolder = workspace:FindFirstChild("Characters") and workspace.Characters:FindFirstChild("Bots")
            if botsFolder then
                for _, bot in ipairs(botsFolder:GetChildren()) do
                    if bot:IsA("Model") then
                        local head = getHead(bot)
                        if not head then continue end
                        if head.Transparency == 1 then continue end

                        if not isAlive(bot) then continue end
                        if not isVisible(head, bot) then continue end

                        if lockAnywhere then
                            local dist = (head.Position - camPos).Magnitude
                            if dist < bestDist then
                                bestTarget = head
                                bestDist = dist
                            end
                        else
                            local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                            if onScreen then
                                local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                                local dx = screenPos.X - fPos.X
                                local dy = screenPos.Y - fPos.Y
                                local screenDist = math.sqrt(dx*dx + dy*dy)
                                if screenDist <= fovSize/2 and screenDist < bestDist then
                                    bestTarget = head
                                    bestDist = screenDist
                                end
                            end
                        end
                    end
                end
            end
        end

        if bestTarget then
            cam.CFrame = CFrame.lookAt(camPos, bestTarget.Position)
        end
    end
end)

