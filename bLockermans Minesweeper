-- ===== COLOR SETTINGS ===== --
local BOMB_COLOR = "Really red"
local SAFE_COLOR = "Toothpaste"

-- ===== MINESWEEPER LOGIC ===== --
local PartsFolder = workspace:FindFirstChild("Flag") and workspace.Flag:FindFirstChild("Parts")
if not PartsFolder then
    warn("workspace.Flag.Parts not found")
    PartsFolder = Instance.new("Folder")
end

local OFFSETS = {
    Vector3.new( 1,0, 0), Vector3.new(-1,0, 0),
    Vector3.new( 0,0, 1), Vector3.new( 0,0,-1),
    Vector3.new( 1,0, 1), Vector3.new(-1,0, 1),
    Vector3.new( 1,0,-1), Vector3.new(-1,0,-1),
}

local neighborCache = {}

local function getNeighbors(part, parts)
    if neighborCache[part] then return neighborCache[part] end
    local size = part.Size.X
    local list = {}
    for _,off in ipairs(OFFSETS) do
        local pos = part.Position + off * size
        for _,p in ipairs(parts) do
            if (p.Position - pos).Magnitude < 0.1 then
                table.insert(list, p)
                break
            end
        end
    end
    neighborCache[part] = list
    return list
end

local function isBomb(part)
    return part.BrickColor.Name == BOMB_COLOR
end

local function isSafe(part)
    return part.BrickColor.Name == SAFE_COLOR
end

local function isRevealed(part)
    local gui = part:FindFirstChild("NumberGui")
    return gui and gui:FindFirstChild("TextLabel") ~= nil
end

local function getNumber(part)
    local gui = part:FindFirstChild("NumberGui")
    if not gui then return nil end
    local label = gui:FindFirstChild("TextLabel")
    if not label then return nil end
    local num = tonumber(label.Text)
    if num and num >= 1 and num <= 8 then return num end
    return nil
end

local function hasModel(part)
    for _,c in ipairs(part:GetChildren()) do
        if c:IsA("Model") then return true end
    end
    return false
end

local function clickCell(part)
    local cd = part:FindFirstChild("ClickDetector")
    if cd then
        fireclickdetector(cd)
        return true
    end
    return false
end

task.spawn(function()
    while task.wait(flagDelay) do
        local parts = PartsFolder:GetChildren()
        if #parts == 0 then continue end

        if calcEnabled then
            local changed = true
            while changed do
                changed = false
                for _, cell in ipairs(parts) do
                    local number = getNumber(cell)
                    if not number then continue end
                    local neighbors = getNeighbors(cell, parts)
                    local hidden = {}
                    local flagged = 0
                    for _, n in ipairs(neighbors) do
                        if isBomb(n) then
                            flagged = flagged + 1
                        elseif not isSafe(n) and not isRevealed(n) then
                            table.insert(hidden, n)
                        end
                    end
                    if flagged == number and #hidden > 0 then
                        for _, h in ipairs(hidden) do
                            if not isSafe(h) then
                                h.BrickColor = BrickColor.new(SAFE_COLOR)
                                changed = true
                            end
                        end
                    elseif flagged + #hidden == number and #hidden > 0 then
                        for _, h in ipairs(hidden) do
                            if not isBomb(h) then
                                h.BrickColor = BrickColor.new(BOMB_COLOR)
                                changed = true
                            end
                        end
                    end
                end
            end
        end

        if autoFlag and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local closest, dist
            for _, p in ipairs(parts) do
                if not isBomb(p) or hasModel(p) then continue end
                local d = (p.Position - hrp.Position).Magnitude
                if d <= flagDistance and (not dist or d < dist) then
                    local cd = p:FindFirstChild("ClickDetector")
                    if cd then closest, dist = cd, d end
                end
            end
            if closest then fireclickdetector(closest) end
        end
    end
end)

