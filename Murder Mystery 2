local oldGetMouseTargetCFrame = WeaponService.GetMouseTargetCFrame
local oldGetTargetPosition = WeaponService.GetTargetPosition

WeaponService.GetMouseTargetCFrame = function(...)
    if gunSilentAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun") then
        local targetPlr = getNearestMurderer()
        if targetPlr and targetPlr.Character then
            local hrp = targetPlr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then return hrp.CFrame end
        end
    end
    return oldGetMouseTargetCFrame(...)
end

WeaponService.GetTargetPosition = function(...)
    if gunSilentAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Gun") then
        local targetPlr = getNearestMurderer()
        if targetPlr and targetPlr.Character then
            local hrp = targetPlr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then return hrp.CFrame end
        end
    end
    return oldGetTargetPosition(...)
end

task.spawn(function()
    while task.wait(0.1) do
        if not gunAutoShoot then continue end
        local char = LocalPlayer.Character
        if not char then continue end
