local function createESPBillboard(textSize)
    textSize = textSize or 20
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.fromOffset(400, 60)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.StudsOffset = Vector3.new(0, 3, 0)
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.fromScale(1, 1)
    txt.BackgroundTransparency = 1
    txt.TextStrokeColor3 = Color3.new(0, 0, 0)
    txt.TextStrokeTransparency = 0.3
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = textSize
    txt.TextWrapped = true
    txt.RichText = true
    
    return gui, txt
end

local function createBoxAdornment(color, adornee)
    local box = Instance.new("BoxHandleAdornment")
    box.AlwaysOnTop = true
    box.AdornCullingMode = Enum.AdornCullingMode.Automatic
    box.ZIndex = 10
    box.SizeRelativeOffset = Vector3.new(0, 0, 0)
    box.Color3 = color
    box.Transparency = 0.75
    box.Adornee = adornee
    box.Parent = adornee
    box.Visible = false
    return box
end

local function anyPlayerHasWeaponInRange(camPos, range)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local head = char:FindFirstChild("Head")
        if not head then continue end
        local dist = (camPos - head.Position).Magnitude
        if dist <= range then
            if hasItem(plr, "Gun") or hasItem(plr, "Knife") then
                return true
            end
        end
    end
    return false
end

local function localPlayerHasWeapon()
    return hasItem(LocalPlayer, "Gun") or hasItem(LocalPlayer, "Knife")
end

for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        ESPObjects[plr] = {Gui = nil, Text = nil, Boxes = {}}
    end
end

Players.PlayerAdded:Connect(function(plr)
    if plr == LocalPlayer then return end
    ESPObjects[plr] = {Gui = nil, Text = nil, Boxes = {}}
end)

Players.PlayerRemoving:Connect(function(plr)
    if ESPObjects[plr] then
        if ESPObjects[plr].Gui then
            ESPObjects[plr].Gui:Destroy()
        end
        for _, box in pairs(ESPObjects[plr].Boxes) do
            box:Destroy()
        end
        ESPObjects[plr] = nil
    end
end)

task.spawn(function()
    while task.wait(0.03) do
        local camPos = cam.CFrame.Position
        local allPlayersNoWeapon = not anyPlayerHasWeaponInRange(camPos, 1000)
        local lpHasWeapon = localPlayerHasWeapon()
        
        for plr, data in pairs(ESPObjects) do
            local char = plr.Character
            if not char then
                if data.Gui then data.Gui.Enabled = false end
                for _, box in pairs(data.Boxes) do box.Visible = false end
                continue
            end
            
            local head = char:FindFirstChild("Head")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not head or not hum or hum.Health <= 0 then
                if data.Gui then data.Gui.Enabled = false end
                for _, box in pairs(data.Boxes) do box.Visible = false end
                continue
            end
            
            local dist = (camPos - head.Position).Magnitude
            if dist > 1000 then
                if data.Gui then data.Gui.Enabled = false end
                for _, box in pairs(data.Boxes) do box.Visible = false end
                continue
            end
            
            local hasGun = hasItem(plr, "Gun")
            local hasKnife = hasItem(plr, "Knife")
            local roleText = nil
            local color = nil
            
            if hasGun then
                if sheriffsESP then
                    roleText = "Sheriff"
                    color = Color3.new(0, 0.5, 1)
                end
            elseif hasKnife then
                if murderersESP then
                    roleText = "Murderer"
                    color = Color3.new(1, 0, 0)
                end
            else
                if innocentsESP then
                    roleText = "Innocent"
                    if allPlayersNoWeapon and not lpHasWeapon then
                        color = Color3.new(1, 1, 1)
                    else
                        color = Color3.new(0, 1, 0)
                    end
                end
            end
            
            if roleText and color then
                if not data.Gui then
                    data.Gui, data.Text = createESPBillboard(20)
                    data.Gui.Name = "ESP_" .. plr.Name
                    data.Gui.Parent = game:GetService("CoreGui")
                end
                data.Text.TextColor3 = color
                data.Gui.Adornee = head
                data.Gui.Enabled = true
                local offset = 1 + (dist * 0.075)
                data.Gui.StudsOffset = Vector3.new(0, offset, 0)
                data.Text.Text = string.format("<b>%s | %d studs</b>", plr.Name, math.floor(dist))
                
                local newBoxes = {}
                for part, box in pairs(data.Boxes) do
                    if part and part.Parent == char then
                        box.Color3 = color
                        box.Visible = true
                        newBoxes[part] = box
                    else
                        box:Destroy()
                    end
                end
                
                for _, part in ipairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        if not newBoxes[part] then
                            local box = createBoxAdornment(color, part)
                            box.Visible = true
                            newBoxes[part] = box
                        end
                    end
                end
                data.Boxes = newBoxes
            else
                if data.Gui then data.Gui.Enabled = false end
                for _, box in pairs(data.Boxes) do box.Visible = false end
            end
        end
    end
end)

task.spawn(function()
    local lastScan = 0
    while task.wait(0.1) do
        if not gunESP then
            for _, data in pairs(GunESPObjects) do
                if data.Gui then data.Gui.Enabled = false end
                if data.Box then data.Box.Visible = false end
            end
            continue
        end
        
        local camPos = cam.CFrame.Position
        local now = tick()
        if now - lastScan >= 1 then
            lastScan = now
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj.Name == "GunDrop" then
                    if not GunESPObjects[obj] then
                        local gui, txt = createESPBillboard(15)
                        gui.Name = "GunESP"
                        gui.Parent = game:GetService("CoreGui")
                        txt.TextColor3 = Color3.new(1, 1, 1)
                        local box = createBoxAdornment(Color3.new(1, 1, 1), obj)
                        GunESPObjects[obj] = {Gui = gui, Text = txt, Box = box}
                    end
                end
            end
        end
        
        for obj, data in pairs(GunESPObjects) do
            if not obj or not obj.Parent then
                if data.Gui then data.Gui:Destroy() end
                if data.Box then data.Box:Destroy() end
                GunESPObjects[obj] = nil
                continue
            end
            
            local dist = (camPos - obj.Position).Magnitude
            if dist > 1000 then
                data.Gui.Enabled = false
                data.Box.Visible = false
                continue
            end
            
            data.Gui.Adornee = obj
            data.Gui.Enabled = true
            data.Text.Text = string.format("<b>Gun | %d studs</b>", math.floor(dist))
            data.Box.Adornee = obj
            data.Box.Visible = true
        end
    end
end)

