local ESPObjects = {Players={}, Enemies={}, Loots={}}

local function createESPBillboard(color, textSize)
    textSize = textSize or 20
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.fromOffset(400,60)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.StudsOffset = Vector3.new(0,3,0)
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    local txt = Instance.new("TextLabel",gui)
    txt.Size = UDim2.fromScale(1,1)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextStrokeColor3 = Color3.new(0,0,0)
    txt.TextStrokeTransparency = 0.3
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = textSize
    txt.TextWrapped = true
    txt.RichText = true
    return gui,txt
end

local function createBoxAdornment(color, adornee)
    local box = Instance.new("BoxHandleAdornment")
    box.AlwaysOnTop = true
    box.AdornCullingMode = Enum.AdornCullingMode.Automatic
    box.ZIndex = 10
    box.SizeRelativeOffset = Vector3.new(0,0,0)
    box.Color3 = color
    box.Transparency = 0.75
    box.Adornee = adornee
    box.Parent = adornee
    box.Visible = false
    return box
end

task.spawn(function()
    while task.wait(0.03) do
        local camPos = cam.CFrame.Position

        if playersESP then
            local charsFolder = workspace:FindFirstChild("Spawned") and workspace.Spawned:FindFirstChild("Characters")
            if charsFolder then
                for _, char in ipairs(charsFolder:GetChildren()) do
                    if char:IsA("Model") and char ~= LocalPlayer.Character then
                        if not ESPObjects.Players[char] then
                            local color = Color3.new(1,1,1)
                            local gui, txt = createESPBillboard(color,20)
                            gui.Name = "PlayerESP_"..char.Name
                            gui.Parent = game:GetService("CoreGui")
                            ESPObjects.Players[char] = {Gui=gui, Text=txt, Boxes={}}
                        end
                    end
                end
            end
            for char, data in pairs(ESPObjects.Players) do
                if not char.Parent then
                    if data.Gui then data.Gui:Destroy() end
                    for _,box in pairs(data.Boxes) do box:Destroy() end
                    ESPObjects.Players[char] = nil
                    continue
                end
                local head = char:FindFirstChild("Head")
                local hum = char:FindFirstChildOfClass("Humanoid")
                if not head or not hum or hum.Health <= 0 then
                    data.Gui.Enabled = false
                    for _,box in pairs(data.Boxes) do box.Visible = false end
                    continue
                end
                local dist = (camPos - head.Position).Magnitude
                local color = Color3.new(1,1,1)
                data.Text.TextColor3 = color
                data.Gui.Adornee = head
                data.Gui.Enabled = true
                local offset = 1 + (dist * 0.075)
                data.Gui.StudsOffset = Vector3.new(0,offset,0)
                data.Text.Text = string.format("<b>%s | Health: %d | %d studs</b>", char.Name, math.floor(hum.Health), math.floor(dist))

                local newBoxes = {}
                for part,box in pairs(data.Boxes) do
                    if part and part.Parent == char then
                        box.Color3 = color
                        box.Visible = true
                        newBoxes[part] = box
                    else
                        box:Destroy()
                    end
                end
                for _,part in ipairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        if not newBoxes[part] then
                            local box = createBoxAdornment(color,part)
                            box.Visible = true
                            newBoxes[part] = box
                        end
                    end
                end
                data.Boxes = newBoxes
            end
        else
            for _, data in pairs(ESPObjects.Players) do
                if data.Gui then data.Gui.Enabled = false end
                for _,box in pairs(data.Boxes) do box.Visible = false end
            end
        end

        if enemiesESP then
            local enemiesFolder = workspace:FindFirstChild("Spawned") and workspace.Spawned:FindFirstChild("Enemies")
            if enemiesFolder then
                for _, enemy in ipairs(enemiesFolder:GetChildren()) do
                    if enemy:IsA("Model") then
                        if not ESPObjects.Enemies[enemy] then
                            local color = Color3.new(1,0,0)
                            local gui, txt = createESPBillboard(color,20)
                            gui.Name = "EnemyESP_"..enemy.Name
                            gui.Parent = game:GetService("CoreGui")
                            ESPObjects.Enemies[enemy] = {Gui=gui, Text=txt, Boxes={}}
                        end
                    end
                end
            end
            for enemy, data in pairs(ESPObjects.Enemies) do
                if not enemy.Parent then
                    if data.Gui then data.Gui:Destroy() end
                    for _,box in pairs(data.Boxes) do box:Destroy() end
                    ESPObjects.Enemies[enemy] = nil
                    continue
                end
                local head = enemy:FindFirstChild("Head")
                local hum = enemy:FindFirstChildOfClass("Humanoid")
                if not head or not hum or hum.Health <= 0 then
                    data.Gui.Enabled = false
                    for _,box in pairs(data.Boxes) do box.Visible = false end
                    continue
                end
                local dist = (camPos - head.Position).Magnitude
                local color = Color3.new(1,0,0)
                data.Text.TextColor3 = color
                data.Gui.Adornee = head
                data.Gui.Enabled = true
                local offset = 1 + (dist * 0.075)
                data.Gui.StudsOffset = Vector3.new(0,offset,0)
                data.Text.Text = string.format("<b>%s | Health: %d | %d studs</b>", enemy.Name, math.floor(hum.Health), math.floor(dist))

                local newBoxes = {}
                for part,box in pairs(data.Boxes) do
                    if part and part.Parent == enemy then
                        box.Color3 = color
                        box.Visible = true
                        newBoxes[part] = box
                    else
                        box:Destroy()
                    end
                end
                for _,part in ipairs(enemy:GetChildren()) do
                    if part:IsA("BasePart") then
                        if not newBoxes[part] then
                            local box = createBoxAdornment(color,part)
                            box.Visible = true
                            newBoxes[part] = box
                        end
                    end
                end
                data.Boxes = newBoxes
            end
        else
            for _, data in pairs(ESPObjects.Enemies) do
                if data.Gui then data.Gui.Enabled = false end
                for _,box in pairs(data.Boxes) do box.Visible = false end
            end
        end

        if lootsESP then
            local lootFolder = workspace:FindFirstChild("Spawned") and workspace.Spawned:FindFirstChild("MouseIgnoreFolder") and workspace.Spawned.MouseIgnoreFolder:FindFirstChild("Loot")
            if lootFolder then
                local lootItems = {}
                for _, loot in ipairs(lootFolder:GetChildren()) do
                    if loot:IsA("BasePart") or loot:IsA("Model") then
                        table.insert(lootItems, loot)
                    end
                end
                table.sort(lootItems, function(a, b)
                    local partA = a:IsA("BasePart") and a or a:FindFirstChildWhichIsA("BasePart")
                    local partB = b:IsA("BasePart") and b or b:FindFirstChildWhichIsA("BasePart")
                    if not partA or not partB then return false end
                    return (camPos - partA.Position).Magnitude < (camPos - partB.Position).Magnitude
                end)
                for i = 1, math.min(100, #lootItems) do
                    local loot = lootItems[i]
                    if not ESPObjects.Loots[loot] then
                        local color = Color3.new(0,1,0)
                        local gui, txt = createESPBillboard(color,15)
                        gui.Name = "LootESP_"..loot.Name
                        gui.Parent = game:GetService("CoreGui")
                        ESPObjects.Loots[loot] = {Gui=gui, Text=txt}
                    end
                end
            end
            for loot, data in pairs(ESPObjects.Loots) do
                if not loot.Parent then
                    if data.Gui then data.Gui:Destroy() end
                    ESPObjects.Loots[loot] = nil
                    continue
                end
                local part = loot:IsA("BasePart") and loot or loot:FindFirstChildWhichIsA("BasePart")
                if not part then data.Gui.Enabled = false continue end
                local dist = (camPos - part.Position).Magnitude
                data.Gui.Adornee = part
                data.Gui.Enabled = true
                data.Gui.StudsOffset = Vector3.new(0,0,0)
                data.Text.Text = string.format("<b>%s | %d studs</b>", loot.Name, math.floor(dist))
            end
        else
            for _, data in pairs(ESPObjects.Loots) do
                if data.Gui then data.Gui.Enabled = false end
            end
        end
    end
end)

