local function createChamBox(color)
    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Transparency = 1
    box.Filled = false
    box.Color = color
    box.Visible = false
    return box
end

local function updateChamBox(box, hrp, distance)
    if not hrp then
        box.Visible = false
        return
    end
    local screenPos, onScreen = cam:WorldToViewportPoint(hrp.Position)
    if not onScreen then
        box.Visible = false
        return
    end
    local screenWidth, screenHeight = cam.ViewportSize.X, cam.ViewportSize.Y
    local factor = 1 / (screenPos.Z * math.tan(math.rad(cam.FieldOfView * 0.5)) * 2) * 100
    local width = math.floor(screenWidth / 30 * factor)
    local height = math.floor(screenHeight / 20 * factor)
    box.Size = Vector2.new(width, height)
    box.Position = Vector2.new(screenPos.X - width / 2, screenPos.Y - height / 2)
    box.Visible = true
end

local function getWildlifeHeadPart(wildlife)
    local headModel = wildlife:FindFirstChild("Head")
    if headModel and headModel:IsA("Model") then
        local headPart = headModel:FindFirstChildWhichIsA("BasePart")
        if headPart then return headPart end
    end
    return wildlife:FindFirstChild("HumanoidRootPart") or wildlife:FindFirstChildWhichIsA("BasePart")
end

local function getEnemyToolName(enemy)
    for _, child in ipairs(enemy:GetChildren()) do
        if child:IsA("Tool") then
            return child.Name
        end
    end
    for _, child in ipairs(enemy:GetDescendants()) do
        if child:IsA("Tool") then
            return child.Name
        end
    end
    return "Enemy"
end

local function createESPBillboard(color, textSize)
