        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestDist = math.huge

        local function getWildlifeHead(wildlife)
            local headModel = wildlife:FindFirstChild("Head")
            if headModel and headModel:IsA("Model") then
                local headPart = headModel:FindFirstChildWhichIsA("BasePart")
                if headPart then return headPart end
            end
            local rootPart = wildlife:FindFirstChild("HumanoidRootPart")
            if rootPart then return rootPart end
            return wildlife:FindFirstChildWhichIsA("BasePart")
        end

        if targetPlayers then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr == LocalPlayer then continue end
                if tableFind(WhitelistPlayers, plr.Name) then continue end

                local character = plr.Character
                if not character then continue end

                local humanoid = character:FindFirstChild("Humanoid")
                if not humanoid or humanoid.Health <= 0 then continue end

                local head = character:FindFirstChild("Head")
                if not head then continue end

                local dist = (head.Position - camPos).Magnitude
                if dist > 500 then continue end

                local ray = Ray.new(camPos, (head.Position - camPos).Unit * dist)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
                if hit and hit:IsDescendantOf(character) then
                    if lockAnywhere then
                        if dist < bestDist then
                            bestTarget = head
                            bestDist = dist
                        end
                    else
                        local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                        if onScreen then
                            local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                            local dx = screenPos.X - fPos.X
                            local dy = screenPos.Y - fPos.Y
                            local screenDist = math.sqrt(dx*dx + dy*dy)
                            if screenDist <= fovSize/2 and screenDist < bestDist then
                                bestTarget = head
                                bestDist = screenDist
                            end
                        end
                    end
                end
            end
        end

        if targetEnemies then
            local enemiesFolder = workspace:FindFirstChild("Spawned") and workspace.Spawned:FindFirstChild("Enemies")
