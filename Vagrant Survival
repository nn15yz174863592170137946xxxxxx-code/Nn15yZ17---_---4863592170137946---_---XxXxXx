                    box.Visible = false
                    continue
                end
                updateChamBox(box, hrpPart)
            end
        else
            for _, box in pairs(ChamObjects.Enemies) do
                if box then box.Visible = false end
            end
        end

        if wildlifeCham then
            local wildlifeFolder = workspace:FindFirstChild("Spawned") and workspace.Spawned:FindFirstChild("Wildlife")
            if wildlifeFolder then
                for _, wildlife in ipairs(wildlifeFolder:GetChildren()) do
                    if wildlife:IsA("Model") then
                        if not ChamObjects.Wildlife[wildlife] then
                            ChamObjects.Wildlife[wildlife] = createChamBox(Color3.new(0.5,0.5,1))
                        end
                    end
                end
            end
            for wildlife, box in pairs(ChamObjects.Wildlife) do
                if not wildlife.Parent then
                    box:Remove()
                    ChamObjects.Wildlife[wildlife] = nil
                    continue
                end
                local hrpPart = wildlife:FindFirstChild("HumanoidRootPart") or getWildlifeHeadPart(wildlife)
                local hum = wildlife:FindFirstChildOfClass("Humanoid")
                if not hrpPart or not hum or hum.Health <= 0 then
                    box.Visible = false
                    continue
                end
                updateChamBox(box, hrpPart)
            end
        else
            for _, box in pairs(ChamObjects.Wildlife) do
                if box then box.Visible = false end
            end
        end
    end
end)

