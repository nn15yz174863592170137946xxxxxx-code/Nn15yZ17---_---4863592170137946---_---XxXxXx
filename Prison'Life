-- ===== whitelist UI =====
local WhitelistGroup = Tabs.Main:AddLeftGroupbox("Whitelist","boxes")
local WhitelistPlayers = {}
WhitelistGroup:AddInput("WhitelistInput",{Text="Input",Placeholder="(Partial username)"})

local function getClosestPlayer(txt)
    local s = txt:lower()
    local best,dist=nil,999
    for _,plr in pairs(Players:GetPlayers()) do
        local u = plr.Name:lower()
        local d = plr.DisplayName:lower()
        if u:find(s,1,true) or d:find(s,1,true) then
            local pick = (#u < #d) and u or d
            local diff = math.abs(#pick - #s)
            if diff < dist then best,dist = plr,diff end
        end
    end
    return best
end

WhitelistGroup:AddButton("Add",function()
    local t = Options.WhitelistInput.Value
    if t=="" then return Library:Notify("Player not found!",3) end
    local p = getClosestPlayer(t)
    if p and not table.find(WhitelistPlayers,p.Name) then
        table.insert(WhitelistPlayers,p.Name)
        Library:Notify(p.Name.." added!",3)
    else
        Library:Notify("Player not found!",3)
    end
end)

WhitelistGroup:AddButton("Remove",function()
    local t = Options.WhitelistInput.Value
    if t=="" then return Library:Notify("Player not found!",3) end
    local p = getClosestPlayer(t)
    if not p then return Library:Notify("Player not found!",3) end
    for i=#WhitelistPlayers,1,-1 do
        if WhitelistPlayers[i]==p.Name then
            table.remove(WhitelistPlayers,i)
            Library:Notify(p.Name.." removed!",3)
        end
    end
end)

-- ===== create FOV UI =====
local function createFOV()
    if gui then pcall(function() gui:Destroy() end) end
    gui = Instance.new("ScreenGui")
    gui.Name="AimlockFOV"
    gui.ResetOnSpawn=false
    gui.IgnoreGuiInset=true
    gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local function mk(parent,pos,size)
        local f=Instance.new("Frame",parent)
        f.AnchorPoint=Vector2.new(.5,.5)
        f.Position=pos
        f.Size=size
        f.BackgroundColor3=Color3.new(1,1,1)
        f.BorderSizePixel=0
        return f
    end

    crossV = mk(gui,UDim2.new(0.5,0,0.5,0),UDim2.new(0,2,0,14))
    crossH = mk(gui,UDim2.new(0.5,0,0.5,0),UDim2.new(0,14,0,2))

    fovCircle = mk(gui,UDim2.new(0.5,0,0.5,0),UDim2.new(0,fovSize,0,fovSize))
    fovCircle.BackgroundTransparency=1
    Instance.new("UICorner",fovCircle).CornerRadius = UDim.new(1,0)

    local s = Instance.new("UIStroke",fovCircle)
    s.Thickness = 2

    crossH.Visible = false
    crossV.Visible = false
    fovCircle.Visible = false

    task.spawn(function()
        local h=0
        while task.wait(.03) do
            if fovCircle and fovCircle.Visible then
                h=(h+3)%360
                s.Color = Color3.fromHSV(h/360,1,1)
            end
        end
    end)
end
createFOV()

