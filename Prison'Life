-- ===== helpers =====
local MAX_DISTANCE = 1000

local function isHostile(plr)
    local model = workspace:FindFirstChild(plr.Name)
    if not model then return false end
    return model:GetAttribute("Hostile") == true
end

local function isAlive(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function clearLine(from, to, ignore)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = ignore
    params.IgnoreWater = true

    local result = workspace:Raycast(from, to - from, params)
    if not result then return true end
    if ignore and ignore[2] and result.Instance and result.Instance:IsDescendantOf(ignore[2]) then
        return true
    end
    return false
end

-- ===== TeamColor logic (hardcoded, no GUI toggle) =====
local BrightBlue = BrickColor.new("Bright blue")
local BrightOrange = BrickColor.new("Bright orange")
local ReallyRed = BrickColor.new("Really red")

local function teamcolor_should_target(plr)
    local localTeam = LocalPlayer.Team
    local localColor = localTeam and localTeam.TeamColor or LocalPlayer.TeamColor

    if not localColor then
        return isHostile(plr)
    end

    local pTeam = plr.Team
    local pColor = pTeam and pTeam.TeamColor or plr.TeamColor

    if localColor == BrightBlue then
        return isHostile(plr) or (pColor == ReallyRed)
    elseif localColor == BrightOrange then
        if pColor == BrightBlue then return true end
        if pColor == ReallyRed and isHostile(plr) then return true end
        return false
    elseif localColor == ReallyRed then
        if pColor == BrightBlue then return true end
        if pColor == BrightOrange and isHostile(plr) then return true end
        return false
    else
        return isHostile(plr)
    end
end

-- ===== AIMLOCK LOOP ===== --
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local center = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local bestTarget = nil
        local bestDist = math.huge

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if table.find(WhitelistPlayers, plr.Name) then continue end

            local c = plr.Character
            if not c then continue end
            local hum = c:FindFirstChildOfClass("Humanoid")
            local head = c:FindFirstChild("Head")
            if not (hum and hum.Health > 0 and head) then continue end

            if not teamcolor_should_target(plr) then continue end

            if not clearLine(hrp.Position, head.Position, {char, c}) then continue end

            if lockAnywhere then
                local dist = (head.Position - hrp.Position).Magnitude
                if dist < bestDist then
                    bestTarget = head.Position
                    bestDist = dist
                end
            else
                local sp, onScreen = cam:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dx = sp.X - center.X
                    local dy = sp.Y - center.Y
                    local screenDist = math.sqrt(dx*dx + dy*dy)
                    if screenDist <= fovSize/2 and screenDist < bestDist then
                        bestTarget = head.Position
                        bestDist = screenDist
                    end
                end
            end
        end

        if bestTarget then
            cam.CFrame = CFrame.lookAt(cam.CFrame.Position, bestTarget)
        end
    end
end)

-- ===== Auto-shoot loop =====
local SHOOT_DELAY = 0.1
local lastShot = 0
local shotCount = 0
local canNotify = true

RunService.Heartbeat:Connect(function()
    if not AUTO then return end
    if tick() - lastShot < SHOOT_DELAY then return end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if table.find(WhitelistPlayers, plr.Name) then continue end

        local pChar = plr.Character
        local head = pChar and pChar:FindFirstChild("Head")
        if not (head and isAlive(pChar)) then continue end

        if not teamcolor_should_target(plr) then continue end

        if (hrp.Position - head.Position).Magnitude > MAX_DISTANCE then continue end
        if not clearLine(hrp.Position, head.Position, {char, pChar}) then continue end

        local args = {
            {
                {
                    hrp.Position,
                    head.Position,
                    head
                }
            }
        }
        pcall(function() ShootRemote:FireServer(unpack(args)) end)

        lastShot = tick()
        shotCount = shotCount + 1

        if shotCount % 30 == 0 and canNotify then
            canNotify = false
            pcall(function() Library:Notify("Click reload!", 1) end)
            task.delay(1, function() canNotify = true end)
        end

        break
    end
end)

