-- ===== TP Safe Spot ===== --
local tpSafeEnabled = false
local tpSafeLoop = nil
local oceanPos = Vector3.new(-163, 10, -454)
local originalPos = Vector3.new(-186, 467, -412)

MainGroup:AddToggle("TPSafe", {
    Text = "TP Safe Spot",
    Default = false,
    Callback = function(value)
        tpSafeEnabled = value
        if value then
            tpSafeLoop = task.spawn(function()
                while tpSafeEnabled do
                    local char = LocalPlayer.Character
                    if char then
                        for _, part in ipairs(char:GetChildren()) do
                            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                                part.CanCollide = false
                            end
                        end
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local targetPos = workspace:FindFirstChild("Ambient") and workspace.Ambient:FindFirstChild("OceanLoop") and oceanPos or originalPos
                            hrp.CFrame = CFrame.new(targetPos)
                        end
                    end
                    task.wait(0.03)
                end
            end)
        else
            tpSafeLoop = nil
            local char = LocalPlayer.Character
            if char then
                for _, part in ipairs(char:GetChildren()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        part.CanCollide = true
                    end
                end
            end
        end
    end
})

