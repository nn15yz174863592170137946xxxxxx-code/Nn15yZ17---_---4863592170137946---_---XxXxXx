-- ===== Auto Buy Landmine ===== --
local buyThreshold = 10
local buyDelay = 0.5
local buyLandmineEnabled = false
local buyLoop = nil
local buyRange = 22

MainGroup:AddLabel("(Amount of Zombies in 22 studs)", true)
MainGroup:AddSlider("BuyThreshold", {
    Text = "Buy Threshold",
    Min = 1,
    Max = 50,
    Default = 10,
    Rounding = 0,
    Suffix = "",
    Callback = function(value)
        buyThreshold = value
    end
})

MainGroup:AddSlider("BuyDelay", {
    Text = "Buy Delay (sec)",
    Min = 0.1,
    Max = 3,
    Default = 0.5,
    Rounding = 1,
    Callback = function(value)
        buyDelay = value
    end
})

MainGroup:AddToggle("AutoBuyLandmine", {
    Text = "Auto Buy Landmine",
    Default = false,
    Callback = function(value)
        buyLandmineEnabled = value
        if value then
            buyLoop = task.spawn(function()
                while buyLandmineEnabled do
                    local character = LocalPlayer.Character
                    if character and character:FindFirstChild("HumanoidRootPart") then
                        local myPos = character.HumanoidRootPart.Position
                        local zombieCount = 0
                        for _, zombie in ipairs(zombiesFolder:GetChildren()) do
                            if zombie:IsA("Model") then
                                local zHrp = zombie:FindFirstChild("HumanoidRootPart")
                                if zHrp and (zHrp.Position - myPos).Magnitude <= buyRange then
                                    zombieCount = zombieCount + 1
                                end
                            end
                        end
                        if zombieCount >= buyThreshold then
                            gearRemotes.GearPurchase:FireServer("Landmine")
                        end
                    end
                    task.wait(buyDelay)
                end
            end)
        else
            buyLoop = nil
        end
    end
})

