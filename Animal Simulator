local ThemeManager = loadstring(game:HttpGet(repo.."addons/ThemeManager.lua"))()
local SaveManager = loadstring(game:HttpGet(repo.."addons/SaveManager.lua"))()

-- ===== services =====
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- ===== remotes =====
local CoinRemote = RS:WaitForChild("Events"):WaitForChild("CoinEvent")
local HitRemote = RS:WaitForChild("jdskhfsIIIllliiIIIdchgdIiIIIlIlIli")

-- ===== helpers =====
local function getHRP()
	local c = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	return c:WaitForChild("HumanoidRootPart")
end

local function getAnyDummy(folder)
	for _, d in ipairs(folder:GetChildren()) do
		if d:FindFirstChild("HumanoidRootPart") then
			return d
		end
	end
end

local function tpBelowLie(dummy)
	local hrp = getHRP()
	local dhrp = dummy:FindFirstChild("HumanoidRootPart")
	if hrp and dhrp then
		hrp.Anchored = true
		hrp.CFrame =
			dhrp.CFrame
			* CFrame.new(0, -10, 0)
			* CFrame.Angles(math.rad(90), 0, 0)
	end
end

local function tpReleaseForward()
	local hrp = getHRP()
	hrp.CFrame = hrp.CFrame + (hrp.CFrame.LookVector * 25)
	hrp.Anchored = false
end

