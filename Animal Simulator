}

-- ===== INFO =====
Tabs.Info:AddLeftGroupbox("Info","help")
	:AddButton("Join Discord", function()
		setclipboard("https://discord.gg/3NjyJjjXxF")
		Library:Notify("Discord link copied!", 3)
	end)

-- ===== MAIN =====
local FarmGroup = Tabs.Main:AddLeftGroupbox("Autofarm","boxes")

local AutoCoin = false
local AutoDummy = false
local AutoDummy5k = false
local tpDone = false

FarmGroup:AddToggle("AutoCoin",{Text="Auto Collect Coins",Callback=function(v)
	AutoCoin = v
end})

FarmGroup:AddToggle("AutoDummy",{Text="Auto Hit Dummy",Callback=function(v)
	if v then
		AutoDummy5k = false
	end
	AutoDummy = v
	tpDone = false
	if not v then
		tpReleaseForward()
	end
end})

FarmGroup:AddToggle("AutoDummy5k",{Text="Auto Hit 5k Dummy",Callback=function(v)
	if v then
		AutoDummy = false
	end
	AutoDummy5k = v
	tpDone = false
	if not v then
		tpReleaseForward()
	end
end})

-- ===== LOOPS =====
task.spawn(function()
	while task.wait(0.5) do
		if AutoCoin then
			CoinRemote:FireServer()
		end
	end
end)

task.spawn(function()
	while task.wait(0.3) do
		if AutoDummy then
			local d = getAnyDummy(workspace.MAP.dummies)
			if d then
				if not tpDone then
					tpBelowLie(d)
					tpDone = true
				end
				local hum = d:FindFirstChild("Humanoid")
				if hum then
					HitRemote:FireServer(hum, 1)
				end
			end
		elseif AutoDummy5k then
			local d = getAnyDummy(workspace.MAP["5k_dummies"])
			if d then
				if not tpDone then
					tpBelowLie(d)
					tpDone = true
				end
				local hum = d:FindFirstChild("Humanoid")
				if hum then
					HitRemote:FireServer(hum, 1)
				end
			end
		end
	end
end)

