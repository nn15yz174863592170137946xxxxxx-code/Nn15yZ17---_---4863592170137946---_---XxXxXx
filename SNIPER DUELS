-- ===== auto-whitelist ===== --
local function clearWhitelist()
    for i=#WhitelistPlayers,1,-1 do table.remove(WhitelistPlayers,i) end
end

local function autoWhitelistNearby()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    clearWhitelist()
    for _,plr in pairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character then
            local otherPart = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Head")
            if otherPart then
                local d = (otherPart.Position - hrp.Position).Magnitude
                if d <= AUTO_WHITELIST_RADIUS then
                    table.insert(WhitelistPlayers, plr.Name)
                end
            end
        end
    end
    Library:Notify("Auto-whitelist updated ("..tostring(#WhitelistPlayers).." players)", 3)
end

local lastHRPPos = nil
local lastCheck = tick()

local function onCharacterAdded(char)
    task.defer(function()
        task.wait(0.2)
        autoWhitelistNearby()
        lastHRPPos = nil
    end)
    local hrp = char:WaitForChild("HumanoidRootPart", 2)
    if hrp then
        hrp:GetPropertyChangedSignal("CFrame"):Connect(function()
            if lastHRPPos then
                local d = (hrp.Position - lastHRPPos).Magnitude
                if d >= SUDDEN_MOVE_THRESHOLD then
                    autoWhitelistNearby()
                end
            end
            lastHRPPos = hrp.Position
        end)
    end
end

if LocalPlayer.Character then
    onCharacterAdded(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local now = tick()
    if lastHRPPos then
        local d = (hrp.Position - lastHRPPos).Magnitude
        if d >= SUDDEN_MOVE_THRESHOLD then
            autoWhitelistNearby()
        end
    end
    lastHRPPos = hrp.Position
    lastCheck = now
end)

-- ===== aimlock logic ===== --
local function isWhitelisted(name)
    return table.find(WhitelistPlayers, name) ~= nil
end

local function getAimTargets(hrp)
    local targets = {}
    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character.Parent then
            if not isWhitelisted(plr.Name) then
                local humanoid = plr.Character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    local head = plr.Character:FindFirstChild("Head")
                    local part = head or plr.Character:FindFirstChild("HumanoidRootPart")
                    if part then
                        local dist = (part.Position - hrp.Position).Magnitude
                        if dist <= MAX_LOCK_DISTANCE then
                            local ray = Ray.new(hrp.Position, (part.Position - hrp.Position))
                            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character}, false, true)
                            if hit and hit:IsDescendantOf(plr.Character) then
                                if lockAnywhere then
                                    table.insert(targets, {part = part, dist = dist})
                                else
                                    local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                                    local sp, on = cam:WorldToViewportPoint(part.Position)
                                    if on then
                                        local dx, dy = sp.X - fPos.X, sp.Y - fPos.Y
                                        if (dx*dx + dy*dy)^0.5 <= fovSize/2 then
                                            table.insert(targets, {part = part, dist = dist})
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return targets
end

RunService:BindToRenderStep("DON_AimlockSnap", Enum.RenderPriority.Camera.Value + 1, function()
    if not aimEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local targets = getAimTargets(hrp)
    if #targets == 0 then return end

    table.sort(targets, function(a,b) return a.dist < b.dist end)
    local best = targets[1].part
    if best and best.Position then
        local camPos = cam.CFrame.Position
        cam.CFrame = CFrame.new(camPos, best.Position)
    end
end)

