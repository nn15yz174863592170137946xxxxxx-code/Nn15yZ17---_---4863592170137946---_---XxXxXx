-- ===== aimlock loop ===== --
task.spawn(function()
    local processedModels = {}
    local pendingCollection = {}

    while task.wait(0.03) do
        if not aimEnabled then
            processedModels = {}
            pendingCollection = {}
            continue
        end

        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local lpTeam = LocalPlayer.Team
        local lpTeamName = lpTeam and lpTeam.Name
        if lpTeamName ~= "Blue" and lpTeamName ~= "Red" then continue end

        local camPos = cam.CFrame.Position

        local structuresFolder = workspace:FindFirstChild("teamStructures")
        local newModels = {}
        if structuresFolder then
            local enemyFolder = lpTeamName == "Blue" and structuresFolder:FindFirstChild("Red") or structuresFolder:FindFirstChild("Blue")
            if enemyFolder then
                local foldersToScan = {}
                if targetBoats then table.insert(foldersToScan, "boat") end
                if targetBuildings then table.insert(foldersToScan, "building") end
                if targetPlanes then table.insert(foldersToScan, "plane") end

                for _, folderName in ipairs(foldersToScan) do
                    local folder = enemyFolder:FindFirstChild(folderName)
                    if folder then
                        for _, model in ipairs(folder:GetChildren()) do
                            if not model:IsA("Model") then continue end
                            if processedModels[model] or pendingCollection[model] then continue end

                            local destroyed = model:FindFirstChild("destroyed")
                            if destroyed and destroyed:IsA("BoolValue") and destroyed.Value == true then continue end

                            local pivot = model:GetPivot().Position
                            if (pivot - camPos).Magnitude <= 1500 then
                                table.insert(newModels, model)
                            end
                        end
                    end
                end
            end
        end

        if #newModels > 0 then
            table.sort(newModels, function(a, b)
                return (a:GetPivot().Position - camPos).Magnitude < (b:GetPivot().Position - camPos).Magnitude
            end)
            local model = newModels[1]

            local allParts = {}
            local function addPartsFromFolder(folder)
                if not folder then return end
                for _, part in ipairs(folder:GetDescendants()) do
                    if part:IsA("BasePart") then
                        table.insert(allParts, part)
                    end
                end
            end

            addPartsFromFolder(model:FindFirstChild("hitBox"))
            if #allParts == 0 then
                local body = model:FindFirstChild("body")
                if body then
                    local core = body:FindFirstChild("core")
                    if core and core:IsA("BasePart") then
                        table.insert(allParts, core)
                    else
                        addPartsFromFolder(body)
                    end
                end
            end

            if #allParts > 0 then
                pendingCollection[model] = {
                    allParts = allParts,
                    collected = 0,
                    model = model
                }
            end
        end

        for model, pending in pairs(pendingCollection) do
            if not model.Parent then
                pendingCollection[model] = nil
                continue
            end
            local destroyed = model:FindFirstChild("destroyed")
            if destroyed and destroyed:IsA("BoolValue") and destroyed.Value == true then
                pendingCollection[model] = nil
                processedModels[model] = nil
                continue
            end

            local remaining = #pending.allParts - pending.collected
            if remaining <= 0 then
                pendingCollection[model] = nil
                continue
            end
            local take = math.min(5, remaining)
            local newParts = {}
            for i = pending.collected + 1, pending.collected + take do
                table.insert(newParts, pending.allParts[i])
            end
            pending.collected = pending.collected + take

            if not processedModels[model] then
                processedModels[model] = { parts = newParts }
            else
                for _, p in ipairs(newParts) do
                    table.insert(processedModels[model].parts, p)
                end
            end
        end

        for model, data in pairs(processedModels) do
            if not model.Parent then
                processedModels[model] = nil
            else
                local destroyed = model:FindFirstChild("destroyed")
                if destroyed and destroyed:IsA("BoolValue") and destroyed.Value == true then
                    processedModels[model] = nil
                    pendingCollection[model] = nil
                end
            end
        end

        local bestTargetPos = nil
        local bestDist = math.huge

        if targetPlayers then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr == LocalPlayer then continue end
                if table.find(WhitelistPlayers, plr.Name) then continue end
                if not plr.Team or (plr.Team.Name ~= "Blue" and plr.Team.Name ~= "Red") then continue end
                if plr.Team.Name == lpTeamName then continue end

                local character = plr.Character
                if not character then continue end

                local humanoid = character:FindFirstChild("Humanoid")
                if not humanoid or humanoid.Health <= 0 then continue end

                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local head = character:FindFirstChild("Head")
                if not rootPart or not head then continue end
                if head.Transparency == 1 then continue end

                local speed = humanoid.WalkSpeed
                local direction = rootPart.Velocity.Magnitude > 0.5 and rootPart.Velocity.Unit or rootPart.CFrame.LookVector
                local predicted = head.Position + (0.25 * speed) * direction
                local dist = (predicted - camPos).Magnitude
                if dist > 1000 then continue end

                local ray = Ray.new(camPos, (predicted - camPos).Unit * dist)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
                if hit and hit:IsDescendantOf(character) then
                    if lockAnywhere then
                        if dist < bestDist then
                            bestTargetPos = predicted
                            bestDist = dist
                        end
                    else
                        local screenPos, onScreen = cam:WorldToViewportPoint(predicted)
                        if onScreen then
                            local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                            local dx = screenPos.X - fPos.X
                            local dy = screenPos.Y - fPos.Y
                            local screenDist = math.sqrt(dx*dx + dy*dy)
                            if screenDist <= fovSize/2 and screenDist < bestDist then
                                bestTargetPos = predicted
                                bestDist = dist
                            end
                        end
                    end
                end
            end
        end

        for model, data in pairs(processedModels) do
            if bestTargetPos then break end
            if not model.Parent then continue end
            local destroyed = model:FindFirstChild("destroyed")
            if destroyed and destroyed:IsA("BoolValue") and destroyed.Value == true then continue end

            local modelDist = (model:GetPivot().Position - camPos).Magnitude
            if modelDist > 1000 then continue end

            local speedVal = 0
            local speedObj = model:FindFirstChild("speed", true)
            if speedObj and speedObj:IsA("IntValue") then
                speedVal = speedObj.Value
            end

            for _, part in ipairs(data.parts) do
                local partPos = part.Position
                if (partPos - camPos).Magnitude > 1000 then continue end

                local forward = part.CFrame.LookVector
                local predicted = partPos + (0.25 * speedVal) * forward
                local dist = (predicted - camPos).Magnitude
                if dist > 1000 then continue end

                local ray = Ray.new(camPos, (predicted - camPos).Unit * dist)
                local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
                if hit and hit:IsDescendantOf(model) then
                    if lockAnywhere then
                        if dist < bestDist then
                            bestTargetPos = predicted
                            bestDist = dist
                        end
                    else
                        local screenPos, onScreen = cam:WorldToViewportPoint(predicted)
                        if onScreen then
                            local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                            local dx = screenPos.X - fPos.X
                            local dy = screenPos.Y - fPos.Y
                            local screenDist = math.sqrt(dx*dx + dy*dy)
                            if screenDist <= fovSize/2 and screenDist < bestDist then
                                bestTargetPos = predicted
                                bestDist = dist
                            end
                        end
                    end
                    break
                end
            end
        end

        if bestTargetPos then
            cam.CFrame = CFrame.lookAt(camPos, bestTargetPos)
        end
    end
end)

