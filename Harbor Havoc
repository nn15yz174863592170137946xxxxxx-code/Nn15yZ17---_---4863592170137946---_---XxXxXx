local espObjects = {}

local function createESPBillboard(color, offset)
    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.fromOffset(300, 50)
    gui.AlwaysOnTop = true
    gui.Enabled = false
    gui.StudsOffset = offset
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.ClipsDescendants = false

    local txt = Instance.new("TextLabel", gui)
    txt.Size = UDim2.fromScale(1, 1)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextStrokeColor3 = Color3.new(0,0,0)
    txt.TextStrokeTransparency = 0.3
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = 20
    txt.TextWrapped = false
    txt.RichText = true
    return gui, txt
end

local function getPlayerColor(teamName)
    if teamName == "Blue" then
        return Color3.fromRGB(80, 150, 255)   -- brighter blue
    elseif teamName == "Red" then
        return Color3.fromRGB(255, 110, 110)  -- brighter red
    else
        return Color3.new(1, 1, 1)
    end
end

local function getStructureColor(teamName)
    if teamName == "Blue" then
        return Color3.fromRGB(0, 0, 255)      -- standard blue
    elseif teamName == "Red" then
        return Color3.fromRGB(255, 0, 0)      -- standard red
    else
        return Color3.new(0.8, 0.8, 0.8)
    end
end

task.spawn(function()
    while task.wait(0.03) do
        local localChar = LocalPlayer.Character
        local hrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
        local hrpPos = hrp and hrp.Position or cam.CFrame.Position

        local lpTeam = LocalPlayer.Team
        local lpTeamName = lpTeam and lpTeam.Name
        if lpTeamName ~= "Blue" and lpTeamName ~= "Red" then continue end

        for model, data in pairs(espObjects) do
            if not model.Parent then
                data.billboard:Destroy()
                espObjects[model] = nil
            end
        end

        for model, data in pairs(espObjects) do
            if data.type == "Player" then
                local plr = Players:GetPlayerFromCharacter(model)
                if plr then
                    local isTeammate = (plr.Team and plr.Team.Name == lpTeamName)
                    if not playersESP or (not teamESP and isTeammate) then
                        data.billboard:Destroy()
                        espObjects[model] = nil
                    end
                else
                    data.billboard:Destroy()
                    espObjects[model] = nil
                end
            elseif data.type == "Structure" then
                if not structuresESP then
                    data.billboard:Destroy()
                    espObjects[model] = nil
                end
            end
        end

        if playersESP then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr == LocalPlayer then continue end
                if not plr.Team or (plr.Team.Name ~= "Blue" and plr.Team.Name ~= "Red") then continue end

                local character = plr.Character
                if not character then continue end

                local isTeammate = (plr.Team.Name == lpTeamName)
                if not teamESP and isTeammate then continue end

                local hum = character:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then continue end

                local head = character:FindFirstChild("Head")
                local adornee = head or character:FindFirstChild("HumanoidRootPart") or character:FindFirstChildWhichIsA("BasePart")
                if not adornee then continue end

                local modelKey = character
                if not espObjects[modelKey] then
                    local color = getPlayerColor(plr.Team.Name)
                    local gui, txt = createESPBillboard(color, Vector3.new(0, 2.5, 0))
                    gui.Name = plr.Name .. "_ESP"
                    gui.Parent = game:GetService("CoreGui")
                    espObjects[modelKey] = {billboard = gui, text = txt, type = "Player"}
                end

                local data = espObjects[modelKey]
                data.billboard.Adornee = adornee
                data.billboard.Enabled = true
                local dist = (hrpPos - adornee.Position).Magnitude
                local health = math.floor(hum.Health)
                data.text.Text = string.format("<b>Name: %s | Health: %d | Studs: %d</b>", plr.Name, health, math.floor(dist))
            end
        end

        if structuresESP then
            local structuresFolder = workspace:FindFirstChild("teamStructures")
            if structuresFolder then
                local enemyFolder = lpTeamName == "Blue" and structuresFolder:FindFirstChild("Red") or structuresFolder:FindFirstChild("Blue")
                if enemyFolder then
                    for _, child in ipairs(enemyFolder:GetChildren()) do
                        if child:IsA("Model") then
                            local adornee = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
                            if adornee then
                                local modelKey = child
                                if not espObjects[modelKey] then
                                    local color = getStructureColor(enemyFolder.Name)
                                    local gui, txt = createESPBillboard(color, Vector3.new(0, 0, 0))
                                    gui.Name = child.Name .. "_ESP"
                                    gui.Parent = game:GetService("CoreGui")
                                    espObjects[modelKey] = {billboard = gui, text = txt, type = "Structure"}
                                end
                                local data = espObjects[modelKey]
                                data.billboard.Adornee = adornee
                                data.billboard.Enabled = true
                                local dist = (hrpPos - adornee.Position).Magnitude
                                local healthVal = nil
                                local healthNumVal = child:FindFirstChild("health", true)
                                if healthNumVal and healthNumVal:IsA("NumberValue") then healthVal = healthNumVal.Value end
                                local healthText = healthVal and math.floor(healthVal) or "N/A"
                                data.text.Text = string.format("<b>Name: %s | Health: %s | Studs: %d</b>", child.Name, healthText, math.floor(dist))
                            end
                        elseif child:IsA("Folder") then
                            for _, sub in ipairs(child:GetChildren()) do
                                if sub:IsA("Model") then
                                    local adornee = sub.PrimaryPart or sub:FindFirstChildWhichIsA("BasePart")
                                    if adornee then
                                        local modelKey = sub
                                        if not espObjects[modelKey] then
                                            local color = getStructureColor(enemyFolder.Name)
                                            local gui, txt = createESPBillboard(color, Vector3.new(0, 0, 0))
                                            gui.Name = sub.Name .. "_ESP"
                                            gui.Parent = game:GetService("CoreGui")
                                            espObjects[modelKey] = {billboard = gui, text = txt, type = "Structure"}
                                        end
                                        local data = espObjects[modelKey]
                                        data.billboard.Adornee = adornee
                                        data.billboard.Enabled = true
                                        local dist = (hrpPos - adornee.Position).Magnitude
                                        local healthVal = nil
                                        local healthNumVal = sub:FindFirstChild("health", true)
                                        if healthNumVal and healthNumVal:IsA("NumberValue") then healthVal = healthNumVal.Value end
                                        local healthText = healthVal and math.floor(healthVal) or "N/A"
                                        data.text.Text = string.format("<b>Name: %s | Health: %s | Studs: %d</b>", sub.Name, healthText, math.floor(dist))
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

