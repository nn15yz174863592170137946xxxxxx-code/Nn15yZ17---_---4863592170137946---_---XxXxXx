AimGui.ResetOnSpawn=false

local btn = Instance.new("TextButton",AimGui)
btn.Size=UDim2.new(0,140,0,40)
btn.Position=UDim2.new(.875,0,.125,0)
btn.Text="Aimlock : OFF"
btn.TextColor3=Color3.new(1,1,1)
btn.BackgroundColor3=Color3.new(0,0,0)
btn.TextScaled=true
btn.Font=Enum.Font.SourceSansBold
btn.Draggable=true
Instance.new("UICorner",btn).CornerRadius=UDim.new(0,10)

local function updateBtn()
    if aimEnabled then
        btn.Text="Aimlock : ON"
        btn.BackgroundColor3=Color3.fromRGB(255,128,0)
        crossH.Visible=true
        crossV.Visible=true
        fovCircle.Visible=true
    else
        btn.Text="Aimlock : OFF"
        btn.BackgroundColor3=Color3.new(0,0,0)
        crossH.Visible=false
        crossV.Visible=false
        fovCircle.Visible=false
    end
end

local function toggleAim(v)
    aimEnabled=v
    Toggles.EnableAimlock:SetValue(v)
    updateBtn()
end

btn.MouseButton1Click:Connect(function() toggleAim(not aimEnabled) end)
game:GetService("UserInputService").InputBegan:Connect(function(i,g)
    if g then return end
    if i.KeyCode.Name == aimKey then toggleAim(not aimEnabled) end
end)
Toggles.EnableAimlock:OnChanged(function(v) task.spawn(function() toggleAim(v) end) end)
updateBtn()

-- ===== aimlock loop ===== --
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestDist = math.huge

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if table.find(WhitelistPlayers, plr.Name) then continue end

            local character = plr.Character
            if not character then continue end

            local humanoid = character:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end

            local head = character:FindFirstChild("Head")
            if not head then continue end

            local ray = Ray.new(camPos, (head.Position - camPos).Unit * (head.Position - camPos).Magnitude)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char}, false, true)
            if hit and hit:IsDescendantOf(character) then
                if lockAnywhere then
                    local dist = (head.Position - camPos).Magnitude
                    if dist < bestDist then
                        bestTarget = head
                        bestDist = dist
                    end
                else
                    local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                        local dx = screenPos.X - fPos.X
                        local dy = screenPos.Y - fPos.Y
                        local screenDist = math.sqrt(dx*dx + dy*dy)
                        if screenDist <= fovSize/2 and screenDist < bestDist then
                            bestTarget = head
                            bestDist = screenDist
                        end
                    end
                end
            end
        end

        if bestTarget then
            cam.CFrame = CFrame.lookAt(camPos, bestTarget.Position)
        end
    end
end)

