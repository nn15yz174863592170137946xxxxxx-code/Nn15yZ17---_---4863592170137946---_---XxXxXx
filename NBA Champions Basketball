-- ===== Remote Override ===== --
local currentReleaseValue = nil
local releaseToggles = {}
local randomToggle = nil

local function findFinishShotRemote()
    local function search(container)
        for _, child in ipairs(container:GetChildren()) do
            if child.Name == "FinishShot" and child:IsA("RemoteEvent") then
                return child
            end
            local found = search(child)
            if found then return found end
        end
        return nil
    end
    return search(game:GetService("ReplicatedStorage"))
end

local finishShotRemote = findFinishShotRemote()
if not finishShotRemote then
    finishShotRemote = game:GetService("ReplicatedStorage"):FindFirstChild("Comms")
        and game.ReplicatedStorage.Comms:FindFirstChild("ActionProvider")
        and game.ReplicatedStorage.Comms.ActionProvider:FindFirstChild("RE")
        and game.ReplicatedStorage.Comms.ActionProvider.RE:FindFirstChild("FinishShot")
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if currentReleaseValue and method == "FireServer" and self == finishShotRemote then
        if args[2] ~= nil then
            args[2] = currentReleaseValue
            return oldNamecall(self, unpack(args))
        end
    end
    
    return oldNamecall(self, ...)
end)

local function setReleaseValue(val, toggleName)
    if val == nil then
        currentReleaseValue = nil
    else
        currentReleaseValue = val
        for name, toggle in pairs(releaseToggles) do
            if name ~= toggleName then
                toggle:SetValue(false)
            end
        end
        if randomToggle and randomToggle:GetValue() then
            randomToggle:SetValue(false)
        end
    end
end

-- ===== Auto Shoot ===== --
local AutoShootGroup = Tabs.Main:AddLeftGroupbox("Auto Shoot","boxes")

local ReleaseList = {
    {Name="Perfect Release", Value=1},
    {Name="Slightly Early",  Value=0.75},
    {Name="Early",           Value=0.7},
    {Name="Very Early",      Value=0.5},
}

for _, item in ipairs(ReleaseList) do
    releaseToggles[item.Name] = AutoShootGroup:AddToggle("Release_"..item.Name, {
        Text = item.Name,
        Default = false,
        Callback = function(v)
            if v then
                setReleaseValue(item.Value, item.Name)
                Library:Notify(item.Name.." enabled", 3)
            else
                if currentReleaseValue == item.Value then
                    setReleaseValue(nil)
                end
            end
        end
    })
end

-- ===== Auto Random ===== --
local RandomGroup = Tabs.Main:AddRightGroupbox("Auto Random","shuffle")

local Weights = {
    ["Perfect Release"] = 0,
    ["Slightly Early"]  = 0,
    ["Early"]           = 0,
    ["Very Early"]      = 0,
}

local Values = {
    ["Perfect Release"] = 1,
    ["Slightly Early"]  = 0.75,
    ["Early"]           = 0.7,
    ["Very Early"]      = 0.5,
}

local randomEnabled = false
local randomLoop = nil

local function pickRandom()
    local pool = {}
    for name, weight in pairs(Weights) do
        for _ = 1, weight do
            table.insert(pool, name)
        end
    end
    if #pool > 0 then
        local chosen = pool[math.random(#pool)]
        currentReleaseValue = Values[chosen]
    end
end

local function startRandomLoop()
    if randomLoop then return end
    randomLoop = task.spawn(function()
        while randomEnabled do
            pickRandom()
            task.wait(0.1)
        end
        randomLoop = nil
    end)
end

local function stopRandomLoop()
    randomEnabled = false
    if randomLoop then
        task.cancel(randomLoop)
        randomLoop = nil
    end
    currentReleaseValue = nil
end

randomToggle = RandomGroup:AddToggle("AutoRandom",{
    Text = "Auto Random",
    Default = false,
    Callback = function(v)
        if v then
            for name, toggle in pairs(releaseToggles) do
                toggle:SetValue(false)
            end
            randomEnabled = true
            startRandomLoop()
            Library:Notify("Auto Random enabled", 3)
        else
            stopRandomLoop()
            Library:Notify("Auto Random disabled", 3)
        end
    end
})

RandomGroup:AddSlider("PerfectSlider", {Text="Perfect Release", Min=0, Max=100, Default=0, Callback=function(v) Weights["Perfect Release"]=v end})
