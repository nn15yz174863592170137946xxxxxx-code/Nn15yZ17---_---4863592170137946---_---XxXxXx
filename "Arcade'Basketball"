-- ===== Remote Value Override ===== --
local currentReleaseValue = nil
local releaseToggles = {}

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if currentReleaseValue and method == "FireServer" and self.Name == "Shoot" and self.Parent and self.Parent.Name == "Events" then
        if args[2] ~= nil then
            args[2] = currentReleaseValue
            return oldNamecall(self, unpack(args))
        end
    end
    
    return oldNamecall(self, ...)
end)

local function setReleaseValue(val, toggleName)
    if val == nil then
        currentReleaseValue = nil
    else
        currentReleaseValue = val
        for name, toggle in pairs(releaseToggles) do
            if name ~= toggleName then
                toggle:SetValue(false)
            end
        end
    end
end

-- ===== Auto Shoot (Release Override) ===== --
local AutoShootGroup = Tabs.Main:AddLeftGroupbox("Auto Shoot","boxes")

AutoShootGroup:AddLabel("Doesn't work with dunk", true)
local ReleaseList = {
    {Name="Perfect Release", Value=-0.98},
    {Name="Good Release",    Value=-0.90},
    {Name="Slightly Early",  Value=-0.85},
    {Name="Early",           Value=-0.80},
    {Name="Very Early",      Value=-0.50},
}

for _, item in ipairs(ReleaseList) do
    releaseToggles[item.Name] = AutoShootGroup:AddToggle("Release_"..item.Name, {
        Text = item.Name,
        Default = false,
        Callback = function(v)
            if v then
                setReleaseValue(item.Value, item.Name)
                Library:Notify(item.Name.." enabled", 3)
            else
                if currentReleaseValue == item.Value then
                    setReleaseValue(nil)
                end
            end
        end
    })
end

-- ===== Ball Hitbox ===== --
local BallGroup = Tabs.Main:AddLeftGroupbox("Misc","basketball")

local BallHitboxEnabled = false
local BIG = Vector3.new(15,15,15)
local MEDIUM = Vector3.new(1,1,1)
local NORMAL = Vector3.new(1,1,1)
local originalBallData = {}
local lastPos = nil
local MOVEMENT_THRESHOLD = 0.5

local function getLocalPlayerBall()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("Basketball")
end

local function isBallNearAnyPlayer(ball)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp and (ball.Position - hrp.Position).Magnitude < 5 then
                    return true
                end
            end
        end
    end
    return false
end

task.spawn(function()
    while task.wait() do
        if not BallHitboxEnabled then
            continue
        end

        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        local isMoving = false
        if hrp and lastPos then
            isMoving = (hrp.Position - lastPos).Magnitude > MOVEMENT_THRESHOLD
        end
        if hrp then
            lastPos = hrp.Position
        end

        local localBall = getLocalPlayerBall()
        local localBallPos = localBall and localBall.Position

        local basketballs = workspace:FindFirstChild("Basketballs")
        if basketballs then
            for _, ball in ipairs(basketballs:GetDescendants()) do
                if ball:IsA("MeshPart") and ball.Name == "Basketball" then
                    if not originalBallData[ball] then
                        originalBallData[ball] = {Size = ball.Size, Transparency = ball.Transparency}
                    end

                    if ball == localBall then
                        ball.Size = NORMAL
                        ball.Transparency = 0
                    elseif localBallPos and (ball.Position - localBallPos).Magnitude < 5 then
                        ball.Size = NORMAL
                        ball.Transparency = 0
                    elseif isBallNearAnyPlayer(ball) then
                        ball.Size = BIG
                        ball.Transparency = 0.8
                    elseif isMoving then
                        ball.Size = BIG
                        ball.Transparency = 0.8
                    else
                        ball.Size = MEDIUM
                        ball.Transparency = 0.5
                    end
                end
            end
        end

        local courts = workspace:FindFirstChild("Courts")
        if courts then
            for _, court in ipairs(courts:GetChildren()) do
                local ball = court:FindFirstChild("Basketball")
                if ball and ball:IsA("MeshPart") then
                    if not originalBallData[ball] then
                        originalBallData[ball] = {Size = ball.Size, Transparency = ball.Transparency}
                    end

                    if ball == localBall then
                        ball.Size = NORMAL
                        ball.Transparency = 0
                    elseif localBallPos and (ball.Position - localBallPos).Magnitude < 5 then
                        ball.Size = NORMAL
                        ball.Transparency = 0
                    elseif isBallNearAnyPlayer(ball) then
                        ball.Size = BIG
                        ball.Transparency = 0.8
                    elseif isMoving then
                        ball.Size = BIG
                        ball.Transparency = 0.8
                    else
                        ball.Size = MEDIUM
                        ball.Transparency = 0.5
                    end
                end
            end
        end
    end
end)

BallGroup:AddToggle("BallHitboxToggle",{
    Text = "Ball Hitbox",
    Default = false,
    Callback = function(v)
        BallHitboxEnabled = v
        if not v then
            for ball, data in pairs(originalBallData) do
                if ball and ball.Parent then
                    ball.Size = data.Size
                    ball.Transparency = data.Transparency
                end
            end
            originalBallData = {}
            lastPos = nil
        end
    end
})

