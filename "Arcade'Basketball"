-- ===== Auto Shoot Random ===== --
local RandomGroup = Tabs.Main:AddRightGroupbox("Auto Shoot Random","shuffle")

local Weights = {
    ["Perfect Release"] = 0,
    ["Good Release"]    = 0,
    ["Slightly Early"]  = 0,
    ["Early"]           = 0,
    ["Very Early"]      = 0,
}

local Values = {
    ["Perfect Release"] = -0.98,
    ["Good Release"]    = -0.90,
    ["Slightly Early"]  = -0.85,
    ["Early"]           = -0.80,
    ["Very Early"]      = -0.50,
}

local randomEnabled = false

local function pickRandom()
    local pool = {}
    for name, weight in pairs(Weights) do
        for _ = 1, weight do
            table.insert(pool, name)
        end
    end
    if #pool > 0 then
        local chosen = pool[math.random(#pool)]
        currentReleaseValue = Values[chosen]
    end
end

RandomGroup:AddToggle("AutoRandom",{
    Text = "Auto Random",
    Default = false,
    Callback = function(v)
        randomEnabled = v
        if not v then
            -- optionally disable override when random stops
        end
    end
})

RandomGroup:AddSlider("PerfectSlider",{Text="Perfect Release",Min=0,Max=100,Default=0,Callback=function(v) Weights["Perfect Release"]=v end})
RandomGroup:AddSlider("GoodSlider",   {Text="Good Release",   Min=0,Max=100,Default=0,Callback=function(v) Weights["Good Release"]=v end})
RandomGroup:AddSlider("SlightlySlider",{Text="Slightly Early", Min=0,Max=100,Default=0,Callback=function(v) Weights["Slightly Early"]=v end})
RandomGroup:AddSlider("EarlySlider",  {Text="Early",          Min=0,Max=100,Default=0,Callback=function(v) Weights["Early"]=v end})
RandomGroup:AddSlider("VerySlider",   {Text="Very Early",     Min=0,Max=100,Default=0,Callback=function(v) Weights["Very Early"]=v end})

task.spawn(function()
    while true do
        if randomEnabled then
            pickRandom()
        end
        task.wait(0.1)
    end
end)

