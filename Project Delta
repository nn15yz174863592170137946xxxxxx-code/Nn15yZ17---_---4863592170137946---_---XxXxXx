local WhitelistGroup = Tabs.Main:AddLeftGroupbox("Whitelist","boxes")
local WhitelistPlayers = {}
WhitelistGroup:AddInput("WhitelistInput",{Text="Input",Placeholder="(Partial username)"})

local function getClosestPlayer(txt)
    local s = txt:lower()
    local best,dist=nil,999
    for _,plr in pairs(Players:GetPlayers()) do
        local u = plr.Name:lower()
        local d = plr.DisplayName:lower()
        if u:find(s,1,true) or d:find(s,1,true) then
            local pick = (#u < #d) and u or d
            local diff = math.abs(#pick - #s)
            if diff < dist then best,dist = plr,diff end
        end
    end
    return best
end

WhitelistGroup:AddButton("Add",function()
    local t = Options.WhitelistInput.Value
    if t=="" then return Library:Notify("Player not found!",3) end
    local p = getClosestPlayer(t)
    if p and not table.find(WhitelistPlayers,p.Name) then
        table.insert(WhitelistPlayers,p.Name)
        Library:Notify(p.Name.." added!",3)
    else
        Library:Notify("Player not found!",3)
    end
end)

WhitelistGroup:AddButton("Remove",function()
    local t = Options.WhitelistInput.Value
    if t=="" then return Library:Notify("Player not found!",3) end
    local p = getClosestPlayer(t)
    if not p then return Library:Notify("Player not found!",3) end
    for i=#WhitelistPlayers,1,-1 do
        if WhitelistPlayers[i]==p.Name then
            table.remove(WhitelistPlayers,i)
            Library:Notify(p.Name.." removed!",3)
        end
    end
end)

