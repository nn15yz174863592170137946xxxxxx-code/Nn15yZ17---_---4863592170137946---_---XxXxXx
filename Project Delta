-- ===== Box =====
local PlayersChamEnabled = true
local EnemiesChamEnabled = true
local PlayersChamCache = {}
local EnemiesChamCache = {}

local function createChamBox(color)
    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Transparency = 1
    box.Filled = false
    box.Color = color
    box.Visible = false
    return box
end

local function updateBox(box, hrp)
    if not hrp then
        box.Visible = false
        return
    end
    local screenPos, onScreen = cam:WorldToViewportPoint(hrp.Position)
    if not onScreen then
        box.Visible = false
        return
    end
    local factor = 1 / (screenPos.Z * math.tan(math.rad(cam.FieldOfView * 0.5)) * 2) * 100
    local width = math.floor(cam.ViewportSize.Y / 20 * factor)
    local height = math.floor(cam.ViewportSize.X / 30 * factor)
    box.Size = Vector2.new(width, height)
    box.Position = Vector2.new(screenPos.X - width / 2, screenPos.Y - height / 2)
    box.Visible = true
end

