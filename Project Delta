local currentMuzzleVelocity = nil
local currentProjectileDrop = nil
local lastWeaponName = nil

local function getWeaponData(weaponName)
    local rangedWeapons = game:GetService("ReplicatedStorage"):FindFirstChild("RangedWeapons")
    if not rangedWeapons then return nil, nil end
    local weapon = rangedWeapons:FindFirstChild(weaponName)
    if not weapon then return nil, nil end
    local ammoCallSign = weapon:GetAttribute("DefaultAmmoCallSign")
    if not ammoCallSign then return nil, nil end
    local ammoTypes = game:GetService("ReplicatedStorage"):FindFirstChild("AmmoTypes")
    if not ammoTypes then return nil, nil end
    for _, ammo in ipairs(ammoTypes:GetChildren()) do
        if ammo:GetAttribute("CallSign") == ammoCallSign then
            local muzzleVel = ammo:GetAttribute("MuzzleVelocity")
            local drop = ammo:GetAttribute("ProjectileDrop")
            if muzzleVel and drop then
                return muzzleVel, drop
            end
        end
    end
    return nil, nil
end

task.spawn(function()
