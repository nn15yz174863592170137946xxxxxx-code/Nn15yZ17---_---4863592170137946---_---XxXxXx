local function getCharacterSize(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 3, 5 end
    local minX, maxX = math.huge, -math.huge
    local minY, maxY = math.huge, -math.huge
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            local size = part.Size
            local pos = part.Position
            local xMin, xMax = pos.X - size.X/2, pos.X + size.X/2
            local yMin, yMax = pos.Y - size.Y/2, pos.Y + size.Y/2
            if xMin < minX then minX = xMin end
            if xMax > maxX then maxX = xMax end
            if yMin < minY then minY = yMin end
            if yMax > maxY then maxY = yMax end
        end
    end
    return (maxX - minX) * 1.2, (maxY - minY) * 1.2
end

local function worldToScreenSize(worldSize, distance)
    local viewportHeight = cam.ViewportSize.Y
    local angle = math.rad(cam.FieldOfView)
    local pixelsPerStud = viewportHeight / (2 * math.tan(angle / 2) * distance)
    return worldSize * pixelsPerStud
end

