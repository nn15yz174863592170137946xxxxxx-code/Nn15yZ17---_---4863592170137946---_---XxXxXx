-- ===== WEAPON DATA TRACKER ===== --
local currentMuzzleVelocity = nil
local currentProjectileDrop = nil
local lastWeaponName = nil

local function getWeaponDataFromInventory(weaponName)
    local playersFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Players")
    if not playersFolder then return nil, nil end
    local playerData = playersFolder:FindFirstChild(LocalPlayer.Name)
    if not playerData then return nil, nil end
    local inventory = playerData:FindFirstChild("Inventory")
    if not inventory then return nil, nil end
    local weapon = inventory:FindFirstChild(weaponName)
    if not weapon then return nil, nil end
    local loadedAmmo = weapon:FindFirstChild("LoadedAmmo")
    if not loadedAmmo then return nil, nil end
    
    local ammoType = nil
    for _, slot in ipairs(loadedAmmo:GetChildren()) do
        if slot:IsA("Folder") or slot:IsA("Instance") then
            local at = slot:GetAttribute("AmmoType")
            if at and at ~= "" then
                ammoType = at
                break
            end
        end
    end
    if not ammoType then return nil, nil end
    
    local ammoTypes = game:GetService("ReplicatedStorage"):FindFirstChild("AmmoTypes")
    if not ammoTypes then return nil, nil end
    local ammo = ammoTypes:FindFirstChild(ammoType)
    if not ammo then return nil, nil end
    
    local muzzleVel = ammo:GetAttribute("MuzzleVelocity")
    local drop = ammo:GetAttribute("ProjectileDrop")
    return muzzleVel, drop
end

local function getWeaponDataOld(weaponName)
    local rangedWeapons = game:GetService("ReplicatedStorage"):FindFirstChild("RangedWeapons")
    if not rangedWeapons then return nil, nil end
    local weapon = rangedWeapons:FindFirstChild(weaponName)
    if not weapon then return nil, nil end
    local ammoCallSign = weapon:GetAttribute("DefaultAmmoCallSign")
    if not ammoCallSign then return nil, nil end
    local ammoTypes = game:GetService("ReplicatedStorage"):FindFirstChild("AmmoTypes")
    if not ammoTypes then return nil, nil end
    for _, ammo in ipairs(ammoTypes:GetChildren()) do
        if ammo:GetAttribute("CallSign") == ammoCallSign then
            local muzzleVel = ammo:GetAttribute("MuzzleVelocity")
            local drop = ammo:GetAttribute("ProjectileDrop")
            if muzzleVel and drop then
                return muzzleVel, drop
            end
        end
    end
    return nil, nil
end

task.spawn(function()
    while true do
        local char = LocalPlayer.Character
        if char then
            local currentWeapon = nil
            for _, child in ipairs(char:GetChildren()) do
                if game:GetService("ReplicatedStorage"):FindFirstChild("RangedWeapons") and game.ReplicatedStorage.RangedWeapons:FindFirstChild(child.Name) then
                    currentWeapon = child
                    break
                elseif child:IsA("Tool") then
                    currentWeapon = child
                    break
                end
            end
            if currentWeapon and currentWeapon.Name ~= lastWeaponName then
                lastWeaponName = currentWeapon.Name
                local mv, drop = getWeaponDataFromInventory(currentWeapon.Name)
                if not mv then
                    mv, drop = getWeaponDataOld(currentWeapon.Name)
                end
                currentMuzzleVelocity, currentProjectileDrop = mv, drop
            end
        end
        task.wait(0.5)
    end
end)

-- ===== AIMLOCK LOOP ===== --
task.spawn(function()
    while task.wait(0.03) do
        if not aimEnabled then continue end
        local char = LocalPlayer.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local camPos = cam.CFrame.Position
        local bestTarget = nil
        local bestTargetPoint = nil
        local bestDist = math.huge

        local function hasPassThrough(part)
            return part and part:IsA("BasePart") and part:GetAttribute("PassThrough") ~= nil
        end

        local function getClosestVisiblePoint(part, targetChar)
            if not part or not part:IsA("BasePart") then return nil, math.huge end
            local size = part.Size
            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
            raycastParams.FilterDescendantsInstances = {char}
            raycastParams.IgnoreWater = true

            local function shouldIgnoreHit(hit)
                return hit and (hit:GetAttribute("PassThrough") ~= nil)
            end

            local centerPoint = part.Position
            local centerDir = (centerPoint - camPos).Unit
            local centerDist = (centerPoint - camPos).Magnitude
            local centerResult = workspace:Raycast(camPos, centerDir * centerDist, raycastParams)
            local centerHit = centerResult and centerResult.Instance

            while centerHit and shouldIgnoreHit(centerHit) do
                raycastParams.FilterDescendantsInstances = {char, centerHit}
                centerResult = workspace:Raycast(camPos, centerDir * centerDist, raycastParams)
                centerHit = centerResult and centerResult.Instance
            end

            if centerHit and (centerHit == part or centerHit:IsDescendantOf(targetChar)) then
                return centerPoint, centerDist
            end

            local corners = {
                Vector3.new( size.X/2,  size.Y/2,  size.Z/2),
                Vector3.new( size.X/2,  size.Y/2, -size.Z/2),
                Vector3.new( size.X/2, -size.Y/2,  size.Z/2),
                Vector3.new( size.X/2, -size.Y/2, -size.Z/2),
                Vector3.new(-size.X/2,  size.Y/2,  size.Z/2),
                Vector3.new(-size.X/2,  size.Y/2, -size.Z/2),
                Vector3.new(-size.X/2, -size.Y/2,  size.Z/2),
                Vector3.new(-size.X/2, -size.Y/2, -size.Z/2)
            }

            local closestPoint = nil
            local closestDist = math.huge

            for _, corner in ipairs(corners) do
                local checkPoint = part.Position + corner
                local direction = (checkPoint - camPos).Unit
                local distance = (checkPoint - camPos).Magnitude
                local raycastResult = workspace:Raycast(camPos, direction * distance, raycastParams)
                local hit = raycastResult and raycastResult.Instance

                while hit and shouldIgnoreHit(hit) do
                    raycastParams.FilterDescendantsInstances = {char, hit}
                    raycastResult = workspace:Raycast(camPos, direction * distance, raycastParams)
                    hit = raycastResult and raycastResult.Instance
                end

                if hit and (hit == part or hit:IsDescendantOf(targetChar)) then
                    if distance < closestDist then
                        closestDist = distance
                        closestPoint = checkPoint
                    end
                end
            end
            return closestPoint, closestDist
        end

        local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local bestCandidate = nil
        local bestScreenDist = math.huge

        local function evaluateCandidate(character)
            if not character then return end
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if not rootPart then return end
            local screenPos, onScreen = cam:WorldToViewportPoint(rootPart.Position)
            if not onScreen then return end
            local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            if distToCenter <= fovSize/2 and distToCenter < bestScreenDist then
                bestScreenDist = distToCenter
                bestCandidate = character
            end
        end

        if targetPlayers then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr == LocalPlayer then continue end
                if plr.Name == "DOM_MINE" then continue end
                if table.find(WhitelistPlayers, plr.Name) then continue end
                local character = plr.Character
                if not character then continue end
                local hum = character:FindFirstChild("Humanoid")
                if not hum or hum.Health <= 0 then continue end
                evaluateCandidate(character)
            end
        end

        if targetEnemies then
            local zone = workspace:FindFirstChild("AiZones")
            if zone then
                for _, enemy in pairs(zone:GetDescendants()) do
                    if enemy:IsA("Model") and enemy:FindFirstChildOfClass("Humanoid") then
                        local hum = enemy:FindFirstChildOfClass("Humanoid")
                        if not hum or hum.Health <= 0 then continue end
                        evaluateCandidate(enemy)
                    end
                end
            end
        end

        if bestCandidate then
            local character = bestCandidate
            local headParts = {}
            local torsoParts = {}
            local limbParts = {}

            local foundAny = false
            for _, child in ipairs(character:GetChildren()) do
                if child:IsA("BasePart") then
                    foundAny = true
                    local name = child.Name:lower()
                    if name:find("head") or name:find("face") then
                        table.insert(headParts, child)
                    elseif name:find("torso") or name:find("upper") or name:find("lower") or name:find("root") then
                        table.insert(torsoParts, child)
                    else
                        table.insert(limbParts, child)
                    end
                end
            end

            if not foundAny then
                for _, child in ipairs(character:GetDescendants()) do
                    if child:IsA("BasePart") then
                        local name = child.Name:lower()
                        if name:find("head") or name:find("face") then
                            table.insert(headParts, child)
                        elseif name:find("torso") or name:find("upper") or name:find("lower") or name:find("root") then
                            table.insert(torsoParts, child)
                        else
                            table.insert(limbParts, child)
                        end
                    end
                end
            end

            if #headParts == 0 and #torsoParts == 0 then
                torsoParts = limbParts
                limbParts = {}
            end

            local partsToScan = {}
            local rand = math.random(100)
            if rand <= headChance and #headParts > 0 then
                partsToScan = headParts
            elseif #torsoParts > 0 then
                partsToScan = torsoParts
            elseif #headParts > 0 then
                partsToScan = headParts
            else
                partsToScan = limbParts
            end

            local bestPart = nil
            local bestPoint = nil
            local bestPartDist = math.huge
            for _, part in ipairs(partsToScan) do
                local point, dist = getClosestVisiblePoint(part, character)
                if point and dist < bestPartDist then
                    bestPartDist = dist
                    bestPart = part
                    bestPoint = point
                end
            end

            if not bestPart then
                local allParts = {}
                for _, part in ipairs(headParts) do table.insert(allParts, part) end
                for _, part in ipairs(torsoParts) do table.insert(allParts, part) end
                for _, part in ipairs(limbParts) do table.insert(allParts, part) end
                for _, part in ipairs(allParts) do
                    local point, dist = getClosestVisiblePoint(part, character)
                    if point and dist < bestPartDist then
                        bestPartDist = dist
                        bestPart = part
                        bestPoint = point
                    end
                end
            end

            if bestPart and bestPoint then
                local screenPos, onScreen = cam:WorldToViewportPoint(bestPoint)
                if lockAnywhere then
                    if bestPartDist < bestDist then
                        bestTarget = bestPart
                        bestTargetPoint = bestPoint
                        bestDist = bestPartDist
                    end
                elseif onScreen then
                    local fPos = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                    local dx = screenPos.X - fPos.X
                    local dy = screenPos.Y - fPos.Y
                    local screenDist = math.sqrt(dx*dx + dy*dy)
                    if screenDist <= fovSize/2 and screenDist < bestDist then
                        bestTarget = bestPart
                        bestTargetPoint = bestPoint
                        bestDist = screenDist
                    end
                end
            end
        end

        if bestTarget then
            local aimPoint = bestTargetPoint or bestTarget.Position
            local targetVel = bestTarget.Velocity or Vector3.new(0,0,0)
            local distance = (camPos - aimPoint).Magnitude
            local predPos = aimPoint

            if currentMuzzleVelocity and currentProjectileDrop and distance > 0 then
                local time = distance / currentMuzzleVelocity
                local moveOffset = targetVel * time
                local dropOffset = Vector3.new(0, currentProjectileDrop * time * time, 0)
                predPos = aimPoint + moveOffset + dropOffset
            else
                local vel = bestTarget.Velocity or Vector3.new(0,0,0)
                predPos = aimPoint + Vector3.new(vel.X * 0.05, vel.Y * 0.01, vel.Z * 0.05)
            end

            cam.CFrame = CFrame.lookAt(camPos, predPos)
        end
    end
end)

